+    const feedAssets = Array.from(bbcFeedXml.matchAll(/<item>([\s\S]*?)<\/item>/g))
+      .map((match) => match[1])
+      .map((itemXml) => {
+        const href = normalizeLink(extractTag(itemXml, "link"));
