+const decodeEntities = (value: string) =>
+  value
+    .replace(/&amp;/g, "&")
+    .replace(/&lt;/g, "<")
+    .replace(/&gt;/g, ">")
+    .replace(/&quot;/g, '"')
+    .replace(/&#39;/g, "'");
+
+const stripCdata = (value: string) =>
+  value.replace(/^<!\[CDATA\[/, "").replace(/\]\]>$/, "").trim();
+
+const extractTag = (input: string, tagName: string) => {
+  const match = input.match(
+    new RegExp(`<${tagName}[^>]*>([\\s\\S]*?)<\\/${tagName}>`),
+  );
+  return match?.[1] ?? "";
+};
+
+const extractAttr = (input: string, tagName: string, attrName: string) => {
+  const match = input.match(
+    new RegExp(`<${tagName}[^>]*\\s${attrName}="([^"]+)"[^>]*\\/?>`),
+  );
+  return match?.[1] ?? "";
+};
+
+const normalizeLink = (value: string) =>
+  decodeEntities(stripCdata(value)).replace(/\?at_medium=RSS&at_campaign=rss$/, "");
+
+const upscaleBbcImage = (url: string) =>
+  url.includes("/standard/240/")
+    ? url.replace("/standard/240/", "/standard/1024/")
+    : url;
+
+const fillerImages = [
