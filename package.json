{
  "name": "astro-starter-pro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:live-cms": "WORDPRESS_API_URL=https://wheat-octopus-390597.hostingersite.com/wp-json astro dev",
    "dev:headless": "npm run wp:setup && concurrently -k -n WP,ASTRO -c cyan,magenta \"npm:wp:serve\" \"npm:dev\"",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "wp:setup": "node scripts/setup-local-wordpress.mjs",
    "wp:seed": "node scripts/generate-wordpress-seed.mjs && wp eval-file scripts/seed-wordpress.php --path=.wp-local",
    "wp:serve": "wp server --host=127.0.0.1 --port=8081 --path=.wp-local",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "fix": "npm run format && npm run lint",
    "test": "vitest",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "build-preview": "npm run build && npm run preview"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.6.1",
    "@iconify-json/lucide": "^1.2.86",
    "@iconify-json/tabler": "^1.2.26",
    "@tailwindcss/vite": "^4.1.18",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^5.16.8",
    "astro-icon": "^1.1.5",
    "gsap": "^3.14.2",
    "lenis": "^1.3.17",
    "remark-reading-time": "^2.0.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.0.6",
    "@typescript-eslint/parser": "^8.52.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.4",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.16"
  }
}
