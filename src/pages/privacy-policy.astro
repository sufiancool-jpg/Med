---
import BaseLayout from "../layouts/BaseLayout.astro";

const metadata = {
  title: "Privacy Policy",
  description:
    "High-level information about contact handling and website analytics on the platform.",
};
---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.08em] text-primary/70">
      Legal
    </p>
    <h1 class="mt-3 text-4xl font-semibold leading-tight md:text-5xl">
      Privacy Policy
    </h1>
    <div class="mt-8 space-y-6 border border-border bg-card p-6 md:p-8">
      <p class="text-sm leading-7 text-muted-foreground">
        This website is used to share information about publications, projects,
        and events. Contact requests submitted through the website are handled by
        the team for communication and follow-up purposes.
      </p>
      <p class="text-sm leading-7 text-muted-foreground">
        The site also uses analytics and performance tools to understand traffic,
        reliability, and overall site performance. These tools are used to improve
        the website experience and maintain stable service.
      </p>
      <p class="text-sm leading-7 text-muted-foreground">
        For privacy-related requests or questions about your data, please contact
        the team through the contact page.
      </p>
      <a
        href="/contact"
        class="inline-flex border border-black px-5 py-2 text-sm font-semibold uppercase tracking-[0.06em] text-primary transition-colors hover:bg-hover hover:text-white"
      >
        Privacy inquiries
      </a>
    </div>
  </section>
</BaseLayout>
