---
import BaseLayout from "../layouts/BaseLayout.astro";
import FilteredArticleArchive from "../components/widgets/FilteredArticleArchive.astro";
import ProjectVisual from "../components/projects/ProjectVisual.astro";
import { getProjects, getPublications } from "../lib/site-data";

const projects = await getProjects();
const publications = await getPublications();

const topProjects = projects.map((project) => ({
  slug: project.slug,
  cardIcon: project.cardIcon,
  title: project.title,
  description: project.description,
  meta: "Project",
  hoverBg: project.color,
  hoverTitle: "#ffffff",
  hoverMeta: "rgba(255,255,255,0.76)",
  hoverBody: "rgba(255,255,255,0.88)",
  hoverIcon: "rgba(255,255,255,0.94)",
  href: project.href,
}));

const archiveArticles = publications
  .filter((publication) => publication.relatedProjectSlugs.length > 0)
  .map((publication) => ({
    title: publication.title,
    summary: publication.previewText,
    author: publication.author,
    date: new Intl.DateTimeFormat("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    }).format(publication.pubDate),
    topic: publication.topics[0] ?? "General",
    platform: publication.relatedProjectTitles[0] ?? "Project",
    hashtags: publication.hashtags.map((tag) => tag.label),
    image: publication.image ?? "/blog/welcome.webp",
    imageAlt: publication.title,
    href: publication.href,
    primaryLabel: publication.relatedProjectTitles[0] ?? "Project",
    typeLabel: publication.outputType,
  }));

const metadata = {
  title: "Projects",
  description:
    "Project briefings and articles across Libya Platform, Africa Nexus, and Gulf Platform.",
};
---

<BaseLayout {metadata}>
  <section id="projects-top-cards" class="bg-white">
    <div class="mx-auto max-w-7xl px-4 pt-10 pb-2 sm:px-6 md:pt-12 md:pb-4 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {topProjects.map((project) => (
          <article
            data-project-card
            style={`--project-hover-bg:${project.hoverBg};--project-hover-title:${project.hoverTitle};--project-hover-meta:${project.hoverMeta};--project-hover-body:${project.hoverBody};--project-hover-icon:${project.hoverIcon};`}
            class="group relative flex overflow-hidden border border-border bg-card p-8 shadow-sm transition-all hover:border-primary/50"
          >
            <div
              data-project-card-bgicon
              class="pointer-events-none absolute -right-4 -top-4 select-none text-primary opacity-[0.08] transition-transform group-hover:scale-110 group-hover:rotate-6"
            >
              <ProjectVisual
                slug={project.slug}
                cardIcon={project.cardIcon}
                class="h-32 w-32"
                strokeWidth={1.2}
              />
            </div>

            <div class="relative z-10 flex h-full flex-col text-left">
              <div data-project-card-icon class="mb-6 text-primary">
                <ProjectVisual
                  slug={project.slug}
                  cardIcon={project.cardIcon}
                  class="h-11 w-11"
                  strokeWidth={1.7}
                />
              </div>
              <p
                data-project-card-meta
                class="mb-2 text-[0.76rem] font-semibold uppercase tracking-[0.08em] text-primary/55"
              >
                <span data-ui-i18n="project.label">Project</span>
              </p>
              <h2 data-project-card-title class="mb-4 text-2xl font-bold text-foreground">
                {project.title}
              </h2>
              <p data-project-card-body class="text-muted-foreground leading-relaxed">
                {project.description}
              </p>
              <a
                href={project.href}
                data-project-card-cta
                class="mt-auto inline-flex items-center gap-2 pt-8 font-semibold text-primary transition-all hover:underline"
              >
                <span data-ui-i18n="project.viewDetails">View details</span>
                <span class="transition-transform group-hover:translate-x-1">→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <FilteredArticleArchive
    items={archiveArticles}
    containerClass="mx-auto max-w-7xl px-4 pt-0 pb-10 sm:px-6 md:pb-12 lg:px-8"
    resultsId="projects-results"
    searchPlaceholder="Search project articles"
    searchPlaceholderKey="archive.searchProjectArticlesGeneric"
  />
</BaseLayout>

<style is:inline>
  [data-project-card]:hover {
    background-color: var(--project-hover-bg);
  }

  [data-project-card]:hover [data-project-card-title] {
    color: var(--project-hover-title);
  }

  [data-project-card]:hover [data-project-card-meta] {
    color: var(--project-hover-meta);
  }

  [data-project-card]:hover [data-project-card-body],
  [data-project-card]:hover [data-project-card-cta],
  [data-project-card]:hover [data-project-card-icon] {
    color: var(--project-hover-body);
  }

  [data-project-card]:hover [data-project-card-icon],
  [data-project-card]:hover [data-project-card-icon] svg {
    color: var(--project-hover-icon);
  }

  [data-project-card]:hover [data-project-card-bgicon] {
    color: var(--project-hover-icon);
    opacity: 0.12;
  }
</style>
