---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FilteredArticleArchive from "../../components/widgets/FilteredArticleArchive.astro";
import {
  isDefaultProfileImage,
  getProjects,
  getProjectBySlug,
  getPublicationsForProject,
} from "../../lib/site-data";

export const prerender = import.meta.env.PROD;

export async function getStaticPaths() {
  const projects = await getProjects();

  return projects.map((project) => ({
    params: { project: project.slug },
  }));
}

const slug = Astro.params.project ?? "";
const project = await getProjectBySlug(slug);

if (!project) {
  return Astro.redirect("/404");
}

const currentStageIndex = Math.max(project.stagePoints.indexOf(project.currentStage), 0);
const timelineProgress =
  project.stagePoints.length > 1 ? (currentStageIndex / (project.stagePoints.length - 1)) * 100 : 0;
const stageItems = project.stagePoints.map((stage, index) => ({
  stage,
  isActive: index <= currentStageIndex,
  isCurrent: index === currentStageIndex,
}));
const visibleProjectLeads = project.leads.filter((lead) => lead.name.trim().length > 0);
const projectLeadLabel = visibleProjectLeads.length === 1 ? "Program Lead" : "Program Leads";
const projectLeadLabelKey =
  visibleProjectLeads.length === 1 ? "project.programLead" : "project.programLeads";

const relatedArticles = (await getPublicationsForProject(project.slug)).map((publication) => ({
  title: publication.title,
  summary: publication.previewText,
  author: publication.author,
  date: new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(publication.pubDate),
  topic: publication.topics[0] ?? "General",
  hashtags: publication.hashtags.map((tag) => tag.label),
  image: publication.image ?? "/blog/welcome.webp",
  imageAlt: publication.title,
  href: publication.href,
  primaryLabel: project.title,
  typeLabel: publication.outputType,
}));

const projectSeoTitle = project.seo.title || project.title;
const projectSeoDescription = project.seo.description || project.description;

const metadata = {
  title: projectSeoTitle,
  description: projectSeoDescription,
  ogImage: project.seo.ogImage,
  canonical: project.seo.canonical,
  noindex: project.seo.noindex,
  ignoreTitleTemplate: Boolean(project.seo.title),
};
---

<BaseLayout {metadata}>
  <section class="border-b border-black/10 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 md:py-12 lg:px-8">
      <div class="mx-auto max-w-5xl text-center">
        <p class="text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-primary/58">
          <span data-ui-i18n="project.label">Project</span>
        </p>
        <h1 class="mt-3 text-[clamp(2.5rem,5vw,4.9rem)] font-bold leading-[0.94] tracking-[-0.04em] text-primary">
          {project.title}
        </h1>
        <p class="mx-auto mt-5 max-w-4xl text-[1.05rem] leading-8 text-primary/74 md:text-[1.14rem]">
          {project.description}
        </p>
      </div>

      {!project.hideProjectBar && project.stagePoints.length > 0 && (
        <div class="mx-auto mt-10 max-w-6xl">
          <div class="space-y-4 md:hidden">
            {stageItems.map((item, index) => (
              <div class="grid grid-cols-[1.2rem_minmax(0,1fr)] gap-4">
                <div class="flex flex-col items-center">
                  <div
                    class:list={[
                      "h-5 w-5 rounded-full border-2 bg-white",
                      item.isActive ? "border-transparent" : "border-black/18",
                    ]}
                    style={item.isActive ? `background:${project.progressColor};` : undefined}
                  ></div>
                  {index < stageItems.length - 1 && (
                    <div
                      class="mt-2 w-[3px] flex-1 rounded-full"
                      style={`min-height:3.25rem;background:${index < currentStageIndex ? project.progressColor : "rgba(10,18,32,0.1)"};`}
                    ></div>
                  )}
                </div>
                <div class="pb-3">
                  <p
                    class:list={[
                      "text-[0.76rem] font-semibold uppercase tracking-[0.1em]",
                      item.isCurrent ? "text-primary" : "text-primary/52",
                    ]}
                  >
                    {item.stage}
                  </p>
                </div>
              </div>
            ))}
          </div>

          <div class="hidden md:block">
            <div class="flex items-center justify-between text-[0.72rem] font-semibold uppercase tracking-[0.1em] text-primary/58">
              <span>{project.stagePoints[0]}</span>
              <span>{project.stagePoints[project.stagePoints.length - 1]}</span>
            </div>
            <div class="relative mt-5">
              <div class="absolute left-0 right-0 top-[0.6rem] h-[3px] bg-black/10"></div>
              <div
                class="absolute left-0 top-[0.6rem] h-[3px]"
                style={`width:${timelineProgress}%;background:${project.progressColor};`}
              ></div>
              <div
                class="relative grid gap-4 pb-1"
                style={`grid-template-columns:repeat(${Math.max(stageItems.length, 1)},minmax(7rem,1fr));`}
              >
                {stageItems.map((item) => (
                  <div class="text-center">
                    <div
                      class:list={[
                        "mx-auto h-5 w-5 rounded-full border-2 bg-white",
                        item.isActive ? "border-transparent" : "border-black/18",
                      ]}
                      style={item.isActive ? `background:${project.progressColor};` : undefined}
                    ></div>
                    <p
                      class:list={[
                        "mt-4 text-[0.74rem] font-semibold uppercase tracking-[0.1em]",
                        item.isCurrent ? "text-primary" : "text-primary/52",
                      ]}
                    >
                      {item.stage}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      )}

      <div class="mt-10 grid gap-8 lg:mt-14 lg:grid-cols-[20%_1px_minmax(0,1fr)] lg:gap-8">
        <aside class="order-2 space-y-6 lg:col-start-1 lg:order-none lg:space-y-8">
          {visibleProjectLeads.length > 0 && (
            <section>
            <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
              <span data-ui-i18n={projectLeadLabelKey}>{projectLeadLabel}</span>
            </p>
            <div class="mt-3 grid gap-4 sm:grid-cols-2 lg:grid-cols-1 lg:gap-6">
              {visibleProjectLeads.map((lead) => (
                <div>
                  {lead.linked && lead.href ? (
                    <a href={lead.href} class="group/lead grid grid-cols-[5.5rem_minmax(0,1fr)] gap-4 items-start lg:block">
                      <img
                        src={lead.image}
                        alt={lead.name}
                        class:list={[
                          "h-[7rem] w-full transition-transform duration-300 group-hover/lead:scale-[1.01] lg:aspect-[4/5] lg:h-auto",
                          isDefaultProfileImage(lead.image)
                            ? "border border-black/12 bg-[#f4f5f3] object-contain p-2 opacity-75"
                            : "object-cover",
                        ]}
                      />
                      <div class="min-w-0">
                        <p class="text-[0.96rem] font-semibold text-primary transition-colors duration-200 group-hover/lead:text-hover lg:mt-3 lg:text-[1rem]">
                          {lead.name}
                        </p>
                        <p class="mt-1 text-[0.84rem] leading-6 text-primary/66 lg:text-[0.88rem]">{lead.role}</p>
                      </div>
                    </a>
                  ) : (
                    <div class="grid grid-cols-[5.5rem_minmax(0,1fr)] gap-4 items-start lg:block">
                      <img
                        src={lead.image}
                        alt={lead.name}
                        class:list={[
                          "h-[7rem] w-full lg:aspect-[4/5] lg:h-auto",
                          isDefaultProfileImage(lead.image)
                            ? "border border-black/12 bg-[#f4f5f3] object-contain p-2 opacity-75"
                            : "object-cover",
                        ]}
                      />
                      <div class="min-w-0">
                        <p class="text-[0.96rem] font-semibold text-primary lg:mt-3 lg:text-[1rem]">{lead.name}</p>
                        <p class="mt-1 text-[0.84rem] leading-6 text-primary/66 lg:text-[0.88rem]">{lead.role}</p>
                      </div>
                    </div>
                  )}
                </div>
              ))}
            </div>
            </section>
          )}

          <section class="border-t border-black/8 pt-5">
            <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
              <span data-ui-i18n="project.workingTeam">Working Team</span>
            </p>
            <ul class="mt-3 space-y-2 text-[0.92rem] leading-6 text-primary/72">
              {project.team.map((member) => (
                <li>
                  {member.linked && member.href ? (
                    <a
                      href={member.href}
                      class="transition-colors duration-200 hover:text-hover hover:underline underline-offset-4"
                    >
                      {member.name}
                    </a>
                  ) : (
                    <span>{member.name}</span>
                  )}
                </li>
              ))}
            </ul>
          </section>

          <section class="border-t border-black/8 pt-5">
            <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
              <span data-ui-i18n="project.donors">Donors</span>
            </p>
            <div class="mt-4 grid grid-cols-1 gap-3">
              {project.donors.map((donor) => (
                <div class="flex min-h-[4.75rem] items-center justify-center border border-black/10 bg-white px-4 py-3">
                  <img
                    src={donor.logo}
                    alt={donor.name}
                    class="max-h-12 w-auto max-w-full object-contain"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          </section>

          {(project.parentProject || project.alignedProject) && (
            <section class="border-t border-black/8 pt-5">
              <div class="grid gap-4">
                {project.parentProject && (
                  <section class="border border-black/10 bg-[#f5f0e7] p-4 lg:p-5">
                    <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
                      <span data-ui-i18n="project.parentProject">Parent Project</span>
                    </p>
                    <p class="mt-3 text-[0.92rem] leading-6 text-primary/72">
                      <span data-ui-i18n="project.parentPrefix">This project sits under the</span>
                      <a
                        href={project.parentProject.href}
                        class="ml-1 font-semibold text-primary underline decoration-black/20 underline-offset-4 transition-colors duration-200 hover:text-hover"
                      >
                        {project.parentProject.title}
                      </a>
                      <span class="ml-1" data-ui-i18n="project.parentSuffix">project.</span>
                    </p>
                  </section>
                )}

                {project.alignedProject && (
                  <section class="border border-black/10 bg-[#eef3ea] p-4 lg:p-5">
                    <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
                      <span data-ui-i18n="project.alignedProject">Aligned Project</span>
                    </p>
                    <p class="mt-3 text-[0.92rem] leading-6 text-primary/72">
                      <span data-ui-i18n="project.alignedPrefix">This project is aligned with the</span>
                      <a
                        href={project.alignedProject.href}
                        class="ml-1 font-semibold text-primary underline decoration-black/20 underline-offset-4 transition-colors duration-200 hover:text-hover"
                      >
                        {project.alignedProject.title}
                      </a>
                      <span class="ml-1" data-ui-i18n="project.alignedSuffix">project.</span>
                    </p>
                  </section>
                )}
              </div>
            </section>
          )}
        </aside>

        <div class="order-3 hidden border-l border-dotted border-black/20 lg:col-start-2 lg:block"></div>

        <div class="order-1 lg:col-start-3 lg:order-none">
          <div
            class="project-prose max-w-4xl text-[0.96rem] leading-7 text-primary/74 md:text-[1rem] md:leading-8"
            set:html={project.contentHtml}
          ></div>

          {project.updates.length > 0 && (
            <section class="mt-10">
              <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
                <span data-ui-i18n="project.currentUpdates">Current Updates</span>
              </p>
              <ul class="mt-4 space-y-3 text-[0.98rem] leading-7 text-primary/74">
                {project.updates.map((update) => (
                  <li class="flex items-start gap-3">
                    <span
                      class="mt-[0.6rem] h-2.5 w-2.5 shrink-0 rounded-full"
                      style={`background:${project.color};`}
                    ></span>
                    <span>{update}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <section class="mt-10">
            <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
              <span data-ui-i18n="project.workstreams">Workstreams</span>
            </p>
            <div class="mt-4 grid gap-4 md:grid-cols-3 md:gap-5">
              {project.focusAreas.map((area) => (
                <article class="border border-black/10 bg-white p-4 md:p-5">
                  <h2 class="text-[1.02rem] font-semibold leading-tight text-primary">
                    {area.title}
                  </h2>
                  <p class="mt-3 text-[0.92rem] leading-7 text-primary/70">
                    {area.description}
                  </p>
                </article>
              ))}
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <div id="project-publications">
    <FilteredArticleArchive
      items={relatedArticles}
      containerClass="mx-auto max-w-7xl px-4 pt-0 pb-10 sm:px-6 md:pb-12 lg:px-8"
      resultsId={`${project.slug}-results`}
      searchPlaceholder={`Search ${project.title} articles`}
      emptyMessage={`No ${project.title} articles match the current search and filter combination.`}
      searchPlaceholderKey="archive.searchProjectArticles"
      searchPlaceholderValue={project.title}
      emptyMessageKey="archive.noProjectArticlesMatch"
      emptyMessageValue={project.title}
      typeOptions={["Publication", "Policy Paper", "Research Report", "Policy Brief", "E-Book", "Insights", "Pod-Cast"]}
    />
  </div>
</BaseLayout>

<style is:inline>
  .project-prose > * + * {
    margin-top: 1.15rem;
  }
</style>
