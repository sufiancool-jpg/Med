---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceList from "../components/widgets/ServiceList.astro";
import Content from "../components/widgets/Content.astro";
import Content2 from "../components/widgets/Content2.astro";
import webDevImg from "../assets/images/services/web-dev.webp";
import seoImg from "../assets/images/services/seo.webp";
import consultingImg from "../assets/images/services/consulting.webp";

const platforms = [
  {
    title: "Libya Platform",
    description: "Field-based research, capacity building, and dialogue support.",
    icon: "lucide:users",
  },
  {
    title: "Africa Nexus",
    description: "Policy analyses, crossroads exchanges, and knowledge ecosystems.",
    icon: "lucide:network",
  },
  {
    title: "Gulf Platform",
    description: "Regional research and dialogue on Europe-Gulf relations and sectoral cooperation.",
    icon: "lucide:link",
  },
];

const metadata = {
  title: "Projects",
  description:
    "Core projects focused on policy-relevant research, dialogue support, and regional cooperation.",
};
---

<BaseLayout {metadata}>
  <Content
    tagline="Projects"
    title="Core Projects"
    description={[
      "Research and dialogue platforms addressing governance, regional security, diplomacy, and strategic policy transitions.",
    ]}
  />
  <ServiceList services={platforms} classes={{ container: "pt-0 md:pt-0" }} />

  <Content
    tagline="Libya Platform"
    title="Field-Based Research and Dialogue Support"
    description={[
      "Multi-track project combining capacity building, youth participation, and policy mentorship with dialogue facilitation.",
    ]}
    classes={{ container: "pb-0 md:pb-0" }}
  />
  <Content2
    items={[
      {
        title: "Permanent Political Platform",
        description:
          "Sustained policy dialogue and engagement pathways for inclusive governance processes.",
      },
      {
        title: "Youth Economic Research Forum",
        description:
          "Knowledge building and policy-oriented research opportunities for youth participation.",
      },
    ]}
    image={webDevImg}
    imageAlt="Libya platform dialogue and research"
    classes={{ container: "pt-0 md:pt-0" }}
  >
    <Fragment>
      <h3 class="mb-2 text-2xl font-bold tracking-tight sm:text-3xl">
        Libya Platform
      </h3>
      Multi-track initiative combining field-based research, capacity building, and dialogue support.
    </Fragment>
  </Content2>

  <Content2
    isReversed={true}
    items={[
      {
        title: "Policy Analyses",
        description:
          "Timely policy-oriented analyses for decision-makers and communities of practice.",
      },
      {
        title: "Crossroads Exchanges",
        description:
          "Knowledge exchange linking experts, young scholars, and policymakers across regions.",
      },
    ]}
    image={seoImg}
    imageAlt="Africa nexus policy analysis and exchange"
  >
    <Fragment>
      <h3 class="mb-2 text-2xl font-bold tracking-tight sm:text-3xl">
        Africa Nexus
      </h3>
      Mission-focused work to create a thriving African-European knowledge ecosystem and support shared prosperity and sustainability.
    </Fragment>
  </Content2>

  <Content2
    items={[
      {
        title: "Geopolitical Dialogue",
        description:
          "Structured dialogue on Europe-Gulf relations, regional security, and long-term cooperation trends.",
      },
      {
        title: "Sectoral Cooperation",
        description:
          "Research on economic, social, and institutional trends shaping Gulf engagement with Europe.",
      },
    ]}
    image={consultingImg}
    imageAlt="Gulf platform research and dialogue"
  >
    <Fragment>
      <h3 class="mb-2 text-2xl font-bold tracking-tight sm:text-3xl">
        Gulf Platform
      </h3>
      Research and dialogue platform focused on Europe-Gulf relations, geopolitical shifts, and sectoral cooperation.
    </Fragment>
  </Content2>
</BaseLayout>
