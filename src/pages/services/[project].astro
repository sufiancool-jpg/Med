---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FilteredArticleArchive from "../../components/widgets/FilteredArticleArchive.astro";
import { projectArticles, projectPages, projectStages } from "../../data/projects";

export async function getStaticPaths() {
  return projectPages.map((project) => ({
    params: { project: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const currentStageIndex = Math.max(projectStages.indexOf(project.currentStage), 0);
const timelineProgress =
  projectStages.length > 1
    ? (currentStageIndex / (projectStages.length - 1)) * 100
    : 0;
const stageItems = projectStages.map((stage, index) => ({
  stage,
  isActive: index <= currentStageIndex,
  isCurrent: index === currentStageIndex,
}));

const relatedArticles = projectArticles
  .filter((article) => article.platform === project.title)
  .map((article) => ({
    ...article,
    primaryLabel: article.platform,
    type: "Publication",
    typeLabel: "Publication",
  }));

const metadata = {
  title: project.title,
  description: project.description,
};
---

<BaseLayout {metadata}>
  <section class="border-b border-black/10 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 md:py-12 lg:px-8">
      <div class="mx-auto max-w-5xl text-center">
        <p class="text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-primary/58">
          Project
        </p>
        <h1 class="mt-3 text-[clamp(2.5rem,5vw,4.9rem)] font-bold leading-[0.94] tracking-[-0.04em] text-primary">
          {project.title}
        </h1>
        <p class="mx-auto mt-5 max-w-4xl text-[1.05rem] leading-8 text-primary/74 md:text-[1.14rem]">
          {project.description}
        </p>
      </div>

      <div class="mx-auto mt-10 max-w-6xl">
        <div class="flex items-center justify-between text-[0.72rem] font-semibold uppercase tracking-[0.1em] text-primary/58">
          <span>Conception</span>
          <span>Implemented</span>
        </div>
        <div class="relative mt-5">
          <div class="absolute left-0 right-0 top-[0.6rem] h-[3px] bg-black/10"></div>
          <div
            class="absolute left-0 top-[0.6rem] h-[3px]"
            style={`width:${timelineProgress}%;background:${project.color};`}
          ></div>
          <div class="relative grid gap-4 md:grid-cols-5">
            {stageItems.map((item) => (
              <div class="text-center">
                <div
                  class:list={[
                    "mx-auto h-5 w-5 rounded-full border-2 bg-white",
                    item.isActive ? "border-transparent" : "border-black/18",
                  ]}
                  style={item.isActive ? `background:${project.color};` : undefined}
                ></div>
                <p
                  class:list={[
                    "mt-4 text-[0.74rem] font-semibold uppercase tracking-[0.1em]",
                    item.isCurrent ? "text-primary" : "text-primary/52",
                  ]}
                >
                  {item.stage}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-14 grid gap-10 lg:grid-cols-[20%_1px_minmax(0,1fr)] lg:gap-8">
        <aside class="space-y-8">
          <section>
            <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
              Program Lead
            </p>
            <div class="mt-3">
              <img
                src={project.lead.image}
                alt={project.lead.name}
                class="aspect-[4/5] w-full object-cover grayscale"
              />
              <p class="mt-3 text-[1rem] font-semibold text-primary">{project.lead.name}</p>
              <p class="mt-1 text-[0.88rem] leading-6 text-primary/66">{project.lead.role}</p>
            </div>
          </section>

          <section class="border-t border-black/8 pt-5">
            <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
              Working Team
            </p>
            <ul class="mt-3 space-y-2 text-[0.92rem] leading-6 text-primary/72">
              {project.team.map((member) => (
                <li>{member}</li>
              ))}
            </ul>
          </section>

          <section class="border-t border-black/8 pt-5">
            <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
              Donors
            </p>
            <div class="mt-4 grid grid-cols-2 gap-3">
              {project.donors.map((donor) => (
                <div class="flex min-h-[4.25rem] items-center justify-center border border-black/10 bg-white p-3">
                  <img
                    src={donor.logo}
                    alt={donor.name}
                    class="max-h-9 w-auto object-contain grayscale"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          </section>
        </aside>

        <div class="hidden lg:block border-l border-dotted border-black/20"></div>

        <div>
          <div class="max-w-4xl space-y-5 text-[1rem] leading-8 text-primary/74">
            {project.overview.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          <section class="mt-10">
            <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
              Current Updates
            </p>
            <ul class="mt-4 space-y-3 text-[0.98rem] leading-7 text-primary/74">
              {project.updates.map((update) => (
                <li class="flex items-start gap-3">
                  <span
                    class="mt-[0.6rem] h-2.5 w-2.5 shrink-0 rounded-full"
                    style={`background:${project.color};`}
                  ></span>
                  <span>{update}</span>
                </li>
              ))}
            </ul>
          </section>

          <section class="mt-10">
            <p class="text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
              Workstreams
            </p>
            <div class="mt-4 grid gap-5 md:grid-cols-3">
              {project.focusAreas.map((area) => (
                <article class="border border-black/10 bg-white p-5">
                  <h2 class="text-[1.02rem] font-semibold leading-tight text-primary">
                    {area.title}
                  </h2>
                  <p class="mt-3 text-[0.92rem] leading-7 text-primary/70">
                    {area.description}
                  </p>
                </article>
              ))}
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <div id="project-publications">
    <FilteredArticleArchive
      items={relatedArticles}
      containerClass="mx-auto max-w-7xl px-4 pt-0 pb-10 sm:px-6 md:pb-12 lg:px-8"
      resultsId={`${project.slug}-results`}
      searchPlaceholder={`Search ${project.title} articles`}
      emptyMessage={`No ${project.title} articles match the current search and filter combination.`}
      typeOptions={["Publication"]}
    />
  </div>
</BaseLayout>
