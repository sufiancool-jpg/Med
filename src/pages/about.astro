---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import Content2 from "../components/widgets/Content2.astro";
import Values from "../components/widgets/Values.astro";
import aboutImage from "../assets/images/about-office.webp";

const metadata = {
  title: "About us",
  description:
    "Research, dialogue, and educational programme offering collective reflection and informed policymaking at national and transnational levels.",
};

const values = [
  {
    title: "Collective Reflection",
    description:
      "The platform offers a space for collective reflection on governance, diplomacy, and regional transformations.",
  },
  {
    title: "Policy-Relevant Research",
    description:
      "Multi-disciplinary and policy-relevant outputs support informed policymaking and advocacy.",
  },
  {
    title: "Dialogue Support",
    description:
      "Dialogue support and track-two engagement connect experts, stakeholders, and decision-makers.",
  },
  {
    title: "Capacity Building",
    description:
      "Mentorship and knowledge exchange strengthen local research capabilities and policy participation.",
  },
  {
    title: "Regional Cooperation",
    description:
      "Workstreams foster cooperation across the Mediterranean, Africa, and Gulf policy spaces.",
  },
  {
    title: "Scenario-Making",
    description:
      "Future studies and scenario-making help shape long-term strategic policy discussions.",
  },
];

const optimizedImage = await getImage({
  src: aboutImage,
  format: "webp",
});
---

<BaseLayout {metadata}>
  <link slot="head" rel="preload" href={optimizedImage.src} as="image" />
  <Content2
    title="About the Platform"
    description={[
      "The Mediterranean Platform is a research, dialogue, and educational programme focused on informed policymaking and advocacy.",
      "It addresses political, socio-economic and security transformations, MENA geopolitics, regional security and diplomacy, and future studies for the broader Mediterranean.",
    ]}
    tagline="About us"
    image={aboutImage}
    imageAlt="Mediterranean policy dialogue and research"
    actions={[
      {
        text: "Contact",
        href: "/contact",
        variant: "primary",
        icon: "lucide:mail",
      },
      {
        text: "Publications",
        href: "/blog",
        variant: "secondary",
        icon: "lucide:arrow-right",
      },
    ]}
  />
  <Values
    items={values}
    columns={3}
    tagline="Approach"
    title="What Defines Our Work"
    subtitle="Principles guiding research, dialogue, and policy engagement"
  />
</BaseLayout>
