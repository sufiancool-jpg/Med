---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import ProtectedEmailLink from "../components/ui/ProtectedEmailLink.astro";
import { getTeamPeople, isDefaultProfileImage } from "../lib/site-data";

const metadata = {
  title: "About us",
  description:
    "Research, dialogue, and educational programme offering collective reflection and informed policymaking at national and transnational levels.",
};

const aboutIntro = [
  "The Mediterranean Platform fosters exchange among academic, policy, and business communities across the Mediterranean and beyond, contributing to the production of high-quality knowledge. Through a broad regional network, it advances multidisciplinary research to support informed decision-making and evidence-based policymaking, while amplifying local perspectives in international debates.",
  "Policy dialogues are at the core of its work, convening stakeholders to address transnational issues, support mediation efforts, and generate operational ideas for diplomatic and business strategies, particularly in complex and conflict-affected settings.",
  "The Platform places young people at the centre of its activities, promoting their participation and equipping them through training and mentorship programmes to become agents of change. It also offers executive training and educational activities designed to foster knowledge exchange, strengthen skills, and build communities of practice across academic, diplomatic, and civil society spheres.",
];

const teamMembers = await getTeamPeople();
const partnerLogos = [
  {
    src: "/Logos/European-Commission.png",
    alt: "European Commission",
  },
  {
    src: "/Logos/Unimed.png",
    alt: "Unimed",
  },
  {
    src: "/Logos/Logo-LDTF.png",
    alt: "LDTF",
  },
  {
    src: "/Logos/PM-SOG-Logo.png.jpg",
    alt: "PM SOG",
  },
  {
    src: "/Logos/download-1.png",
    alt: "Partner logo",
  },
  {
    src: "/Logos/unnamed-e1709546741640.png",
    alt: "Partner logo",
  },
];

---

<BaseLayout {metadata} hideAnnouncementBar={true}>
  <div class="bg-white">
    <section id="mission" class="about-anchor border-b border-black bg-white">
      <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 md:py-10 lg:px-8">
        <div class="grid items-start gap-6 md:grid-cols-[32%_68%] md:gap-8">
          <div class="flex justify-center md:sticky md:top-[calc(var(--nav-h,72px)+2rem)] md:justify-start">
            <div class="mx-auto w-full max-w-[30rem] space-y-5 md:mx-0 md:max-w-[22rem]">
              <img
                src="/Logo3.png"
                alt="Mediterranean Platform"
                class="mx-auto w-full max-w-[19rem] object-contain sm:max-w-[22rem] md:max-w-none"
              />
              <div class="relative aspect-video w-full overflow-hidden border border-black/15 bg-black/5">
                <video
                  data-about-video
                  class="absolute inset-0 h-full w-full object-cover"
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="auto"
                >
                  <source src="/webbg.mp4" type="video/mp4" />
                </video>
                <div class="absolute inset-0 bg-black/10"></div>
              </div>
            </div>
          </div>
          <div>
            <p data-ui-i18n="about.label" class="text-xs font-semibold uppercase tracking-[0.1em] text-primary/65">
              About us
            </p>
            <div class="mt-2.5 space-y-3 text-[0.95rem] leading-[1.58] text-muted-foreground md:text-[0.98rem]">
              {aboutIntro.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="team" class="about-anchor bg-white">
      <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 md:py-14 lg:px-8">
        <div class="grid grid-cols-1 gap-x-6 gap-y-6 md:grid-cols-2 md:gap-y-10 xl:grid-cols-3">
          {teamMembers.map((member) => (
            <article class="about-profile-card grid w-full grid-cols-[5.75rem_minmax(0,1fr)] gap-3 border-b border-dotted border-black/30 pb-4 md:block">
              <a href={member.href} class="block overflow-hidden">
                <img
                  src={member.image}
                  alt={member.name}
                  loading="lazy"
                  class:list={[
                    "about-profile-image h-24 w-full md:aspect-[5/6] md:h-auto",
                    isDefaultProfileImage(member.image)
                      ? "border border-black/12 bg-[#f4f5f3] object-contain p-2 opacity-75"
                      : "object-cover object-center",
                  ]}
                />
              </a>
              <div class="min-w-0 md:mt-3.5">
                <h3 class="text-[0.94rem] font-semibold leading-tight text-foreground md:text-[0.98rem]">
                  <a href={member.href} class="transition-colors hover:text-hover">
                    {member.name}
                  </a>
                </h3>
                <p class="mt-1.5 text-[0.82rem] leading-[1.55] text-muted-foreground md:mt-2.5 md:text-[0.86rem] md:leading-[1.68]">
                  {member.shortBio}
                </p>
                {member.email && (
                  <ProtectedEmailLink
                    email={member.email}
                    class="mt-2.5 inline-flex text-[0.76rem] font-medium text-primary transition-colors hover:text-hover md:mt-3.5 md:text-[0.8rem]"
                  />
                )}
                {(member.linkedinUrl || member.websiteUrl) && (
                  <div class="mt-2 flex items-center gap-2.5">
                    {member.linkedinUrl && (
                      <a
                        href={member.linkedinUrl}
                        aria-label={`${member.name} LinkedIn`}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center justify-center leading-none text-primary transition-colors hover:text-primary/70"
                      >
                        <Icon name="lucide:linkedin" class="h-3.5 w-3.5" />
                      </a>
                    )}
                    {member.websiteUrl && (
                      <a
                        href={member.websiteUrl}
                        aria-label={`${member.name} website`}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center justify-center leading-none text-primary transition-colors hover:text-primary/70"
                      >
                        <Icon name="lucide:globe" class="h-3.5 w-3.5" />
                      </a>
                    )}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 md:pb-16 lg:px-8">
        <div class="about-cta-block flex flex-col items-start gap-2 text-[clamp(1.7rem,3.8vw,3.1rem)] font-semibold leading-[0.94] tracking-[-0.045em] text-black">
          <span data-ui-i18n="about.partneringPrompt">Interested in Partnering with us?</span>
          <a
            href="/contact"
            class="inline-flex items-baseline gap-3 transition-all hover:text-[#42b09a] hover:underline"
          >
            <span data-ui-i18n="about.reachOut">Reach out</span>
          </a>
          <a
            href="/volunteer"
            class="inline-flex items-baseline gap-3 transition-all hover:text-[#42b09a] hover:underline"
          >
            <span data-ui-i18n="about.volunteerNow">volunteer now</span>
          </a>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-4 pb-14 sm:px-6 md:pb-16 lg:px-8">
        <div class="about-partners-block border-t border-dotted border-black/30 pt-6 md:pt-7">
          <p data-ui-i18n="about.collaborations" class="text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-primary/70">
            Our collaborations
          </p>
          <div class="mt-5 grid grid-cols-2 gap-5 md:grid-cols-4 md:gap-6">
            {partnerLogos.map((logo) => (
              <div class="flex h-20 items-center justify-center px-4 md:h-24">
                <img
                  src={logo.src}
                  alt={logo.alt}
                  loading="lazy"
                  class="max-h-12 w-auto max-w-full object-contain md:max-h-14"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  const initAboutVideo = () => {
    document.querySelectorAll("[data-about-video]").forEach((video) => {
      video.muted = true;
      video.defaultMuted = true;
      const playPromise = video.play?.();
      if (playPromise && typeof playPromise.catch === "function") {
        playPromise.catch(() => {});
      }
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAboutVideo, {
      once: true,
    });
  } else {
    initAboutVideo();
  }

  document.addEventListener("astro:after-swap", initAboutVideo);
</script>

<style>
  .about-anchor {
    scroll-margin-top: calc(var(--nav-h, 72px) + 1.25rem);
  }

  .about-profile-image {
    filter: grayscale(1) contrast(1.1) brightness(1.01);
    -webkit-filter: grayscale(1) contrast(1.1) brightness(1.01);
    transition:
      filter 520ms ease,
      -webkit-filter 520ms ease;
  }

  .about-profile-card:hover .about-profile-image,
  .about-profile-card:focus-within .about-profile-image,
  .about-profile-image:hover,
  .about-profile-image:focus {
    filter: grayscale(0.2) contrast(1.04) brightness(1);
    -webkit-filter: grayscale(0.2) contrast(1.04) brightness(1);
  }

  .about-cta-block {
    max-width: 64rem;
  }

  .about-partners-block {
    max-width: 64rem;
  }

  @media (min-width: 768px) {
    .about-cta-block {
      margin-left: 0;
    }

    .about-partners-block {
      margin-left: 0;
    }
  }

  @media (min-width: 1280px) {
    .about-cta-block {
      margin-left: 0;
    }

    .about-partners-block {
      margin-left: 0;
    }
  }
</style>
