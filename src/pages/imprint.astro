---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const metadata = {
  title: "Imprint",
  description: "Basic publisher and contact information for the website.",
};
---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.08em] text-primary/70">
      Legal
    </p>
    <h1 class="mt-3 text-4xl font-semibold leading-tight md:text-5xl">
      Imprint
    </h1>
    <div class="mt-8 grid gap-px border border-border bg-border md:grid-cols-2">
      <div class="bg-background p-6">
        <h2 class="text-lg font-semibold text-foreground">Publisher</h2>
        <p class="mt-3 text-sm leading-7 text-muted-foreground">
          {siteConfig.name}
          <br />
          Via di Villa Emiliani 14
          <br />
          00197 Rome, Italy
        </p>
      </div>
      <div class="bg-background p-6">
        <h2 class="text-lg font-semibold text-foreground">Contact</h2>
        <p class="mt-3 text-sm leading-7 text-muted-foreground">
          Telephone: (+39) 06 8522 5052
          <br />
          Website: {siteConfig.url}
          <br />
          Contact page: /contact
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
