---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FilteredArticleArchive from "../../components/widgets/FilteredArticleArchive.astro";
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const blogEntries = await getCollection("blog");
  const sortedPosts = blogEntries
    .filter((post) => post.data && post.data.pubDate)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(sortedPosts, { pageSize: Math.max(sortedPosts.length, 1) });
}

const { page } = Astro.props;
const blog = page.data;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const publicationTypeOptions = [
  "Policy Paper",
  "Research Report",
  "Policy Brief",
  "E-Book",
  "Pod-Cast",
  "Archive & Commentary",
];

const normalizePublicationType = (value?: string) => {
  if (value === "Podcast" || value === "Pod-Cast") {
    return "Pod-Cast";
  }

  if (value === "Series") {
    return "Archive & Commentary";
  }

  return value ?? "Archive & Commentary";
};

const formatTopic = (value?: string) =>
  value
    ?.split("-")
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ") ?? "General";

const publicationArticles = blog.map((post) => ({
  title: post.data.title,
  summary: post.data.description,
  author: post.data.author,
  date: dateFormatter.format(post.data.pubDate),
  topic: formatTopic(post.data.tags?.[0]),
  type: normalizePublicationType(post.data.category),
  primaryLabel: "Publication",
  typeLabel: normalizePublicationType(post.data.category),
  hashtags: post.data.tags ?? [],
  image: post.data.image ?? "/blog/welcome.webp",
  imageAlt: post.data.title,
  href: `/blog/${post.id}`,
}));

const metadata = {
  title: "Publications",
  description: "Policy-relevant publications, briefs, reports, and editorial analysis.",
};
---

<BaseLayout metadata={metadata}>
  <FilteredArticleArchive
    items={publicationArticles}
    containerClass="mx-auto max-w-7xl px-4 pt-10 pb-10 sm:px-6 md:pt-12 md:pb-12 lg:px-8"
    resultsId="publications-results"
    searchPlaceholder="Search publications"
    emptyMessage="No publications match the current search and filter combination."
    typeOptions={publicationTypeOptions}
  />
</BaseLayout>
