---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/seo/Schema.astro";
import AudioPreviewPlayer from "../../components/widgets/AudioPreviewPlayer.astro";
import RelatedPublicationSlider from "../../components/widgets/RelatedPublicationSlider.astro";
import { Icon } from "astro-icon/components";
import { render } from "astro:content";
import {
  DEFAULT_PROFILE_IMAGE,
  getPublicationBySlug,
  getPublicationCardDate,
  getPublications,
  getSiteSettings,
  getSimilarPublications,
  isDefaultProfileImage,
  shouldShowPublicationLead,
} from "../../lib/site-data";

export const prerender = import.meta.env.PROD;

export async function getStaticPaths() {
  const publications = await getPublications();

  return publications.map((publication) => ({
    params: { slug: publication.slug },
  }));
}

const slug = Astro.params.slug ?? "";
const publication = await getPublicationBySlug(slug);
const siteSettings = await getSiteSettings();

if (!publication) {
  return Astro.redirect("/404");
}

let LocalContent = undefined;
let readingTime = "";

if (publication.source === "local") {
  const { Content, remarkPluginFrontmatter } = await render(publication.localEntry);
  LocalContent = Content;
  readingTime = remarkPluginFrontmatter?.minutesRead
    ? `${Math.ceil(remarkPluginFrontmatter.minutesRead)} min read`
    : "";
}

const formattedDate = publication.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const resolvedAuthorRole = publication.authorRole || `${publication.outputType} contributor`;
const isPodcast = publication.outputTypeSlug === "pod-cast";
const podcastAudioHref = isPodcast ? publication.audioHref : undefined;
const fileDownloadHref = !isPodcast ? publication.downloadHref : undefined;
const trackedDownloadHref = !isPodcast
  ? publication.downloadTrackedHref || publication.downloadHref
  : undefined;
const downloadCountApiHref =
  !isPodcast &&
  fileDownloadHref &&
  siteSettings.showPublicDownloadCounts &&
  publication.source === "wordpress"
    ? publication.downloadCountApiHref
    : undefined;
const resolvedDownloadLabel =
  publication.downloadLabel ||
  (fileDownloadHref?.toLowerCase().endsWith(".pdf")
    ? "Download PDF"
    : "Download publication");
const showLeadPreview = shouldShowPublicationLead(publication);
const publicationAuthors =
  publication.authorPeople.length > 0
    ? publication.authorPeople.map((author) => ({
        ...author,
        role: author.role || publication.authorRole || resolvedAuthorRole,
        image: author.image || DEFAULT_PROFILE_IMAGE,
      }))
    : [
        {
          name: publication.author,
          role: resolvedAuthorRole,
          image: publication.authorImage || DEFAULT_PROFILE_IMAGE,
          href: publication.authorPerson?.href,
          linked: Boolean(publication.authorPerson?.href),
        },
      ];
const authorSectionLabel = publicationAuthors.length === 1 ? "Author" : "Authors";
const similarPublications = (await getSimilarPublications(publication, 5)).map((item) => ({
  href: item.href,
  title: item.title,
  previewText: item.previewText,
  image: item.image,
  outputType: item.outputType,
  date: getPublicationCardDate(item),
  hashtags: item.hashtags.map((tag) => tag.label),
}));
const relatedProjectsLeadLabel =
  publication.relatedProjects.length === 1
    ? "This Publication is part of"
    : "This Publication is part of the following projects";
const seoDescription = publication.previewText || publication.description;

const getProjectButtonTextColor = (color: string) => {
  const normalized = color.trim().replace("#", "");
  const hex = normalized.length === 3
    ? normalized
        .split("")
        .map((value) => `${value}${value}`)
        .join("")
    : normalized;

  if (!/^[0-9a-f]{6}$/i.test(hex)) {
    return "#ffffff";
  }

  const red = parseInt(hex.slice(0, 2), 16);
  const green = parseInt(hex.slice(2, 4), 16);
  const blue = parseInt(hex.slice(4, 6), 16);
  const luminance = (0.299 * red + 0.587 * green + 0.114 * blue) / 255;

  return luminance > 0.65 ? "#0a1220" : "#ffffff";
};

type SidebarAction = {
  href: string;
  label: string;
  icon: "download" | "arrow-down-right";
  download?: boolean;
  target?: "_blank";
  rel?: string;
  downloadCountApiHref?: string;
};

const sidebarActions: SidebarAction[] = [];
const sidebarActionHrefs = new Set<string>();

const pushSidebarAction = (action: SidebarAction) => {
  const normalizedHref = action.href.trim();

  if (!normalizedHref || sidebarActionHrefs.has(normalizedHref)) {
    return;
  }

  sidebarActionHrefs.add(normalizedHref);
  sidebarActions.push(action);
};

if (isPodcast && podcastAudioHref) {
  pushSidebarAction({
    href: "#podcast-player",
    label: "Listen to episode",
    icon: "arrow-down-right",
  });
}

if (fileDownloadHref) {
  pushSidebarAction({
    href: trackedDownloadHref || fileDownloadHref,
    label: resolvedDownloadLabel,
    icon: "download",
    download: true,
    target: "_blank",
    rel: "noreferrer",
    downloadCountApiHref,
  });
}

const metadata = {
  title: publication.title,
  description: seoDescription,
  ogImage: publication.image,
};
---

<BaseLayout metadata={metadata}>
  <Schema
    type="BlogPosting"
    data={{
      title: publication.title,
      description: seoDescription,
      image: publication.image,
      pubDate: publication.pubDate,
      author: publication.author,
      url: Astro.url.href,
    }}
  />

  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 md:py-10 lg:px-8">
      <div class="grid gap-10 xl:grid-cols-[minmax(0,1.55fr)_21rem] xl:items-start">
        <article>
          <div class="max-w-5xl">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.82rem] font-semibold uppercase tracking-[0.12em] text-primary/60">
              <a
                href={`/blog/category/${encodeURIComponent(publication.outputTypeSlug)}`}
                class="transition-colors hover:text-hover"
              >
                {publication.outputType}
              </a>
              <span aria-hidden="true" class="text-primary/35">/</span>
              <span>{formattedDate}</span>
              {readingTime && (
                <>
                  <span aria-hidden="true" class="text-primary/35">/</span>
                  <span>{readingTime}</span>
                </>
              )}
            </div>

            <h1 class="mt-4 text-[clamp(1.4rem,3.5vw,2.9rem)] font-bold leading-[0.96] tracking-[-0.035em] text-primary">
              {publication.title}
            </h1>

            {showLeadPreview && (
              <p class="mt-5 max-w-4xl text-[1.05rem] italic leading-8 text-primary/74 md:text-[1.18rem]">
                {publication.previewText}
              </p>
            )}

            {sidebarActions.length > 0 && (
              <div class="mt-6 grid gap-3 xl:hidden">
                {sidebarActions.map((action) => (
                  <a
                    href={action.href}
                    target={action.target}
                    rel={action.rel}
                    download={action.download}
                    class="inline-flex items-center justify-between border border-black/12 px-5 py-4 text-[0.95rem] font-semibold uppercase tracking-[0.08em] text-primary transition-colors hover:border-black hover:text-hover"
                  >
                    <span class="flex min-w-0 flex-col items-start gap-1">
                      <span>{action.label}</span>
                      {action.downloadCountApiHref && (
                        <span
                          data-download-count
                          data-download-count-endpoint={action.downloadCountApiHref}
                          hidden
                          class="text-[0.72rem] font-medium normal-case tracking-normal text-primary/58"
                        ></span>
                      )}
                    </span>
                    <Icon
                      name={`lucide:${action.icon}`}
                      class="h-4 w-4"
                    />
                  </a>
                ))}
              </div>
            )}

            {isPodcast && podcastAudioHref && (
              <AudioPreviewPlayer
                id="podcast-player"
                audioSrc={podcastAudioHref}
                title={publication.title}
                initialDuration="00:24"
                containerClass="mt-6 max-w-4xl"
              />
            )}
          </div>

          {publication.image && (
            <div class="mt-8 overflow-hidden border border-black/12 bg-white">
              <img
                src={publication.image}
                alt={publication.title}
                class="aspect-[5/4] w-full object-cover"
              />
            </div>
          )}

          <div
            id="publication-body"
            class="publication-prose mt-10 max-w-none text-[1rem] leading-8 text-primary/78"
          >
            {publication.source === "wordpress" ? (
              <Fragment set:html={publication.contentHtml}></Fragment>
            ) : (
              LocalContent && <LocalContent />
            )}
          </div>

          {publication.references.length > 0 && (
            <section class="mt-12 border-t border-black/10 pt-8">
              <h2 class="text-[0.92rem] font-semibold uppercase tracking-[0.08em] text-primary">
                References
              </h2>
              <ul class="mt-5 space-y-3 text-[0.98rem] leading-7 text-primary/74">
                {publication.references.map((reference) => (
                  <li>
                    {reference.url ? (
                      <a
                        href={reference.url}
                        target="_blank"
                        rel="noreferrer"
                        class="transition-colors hover:text-hover"
                      >
                        {reference.name || reference.url}
                      </a>
                    ) : (
                      <span>{reference.name}</span>
                    )}
                  </li>
                ))}
              </ul>
            </section>
          )}
        </article>

        <aside class="xl:sticky xl:top-[calc(var(--nav-h,72px)+2rem)] xl:border-l xl:border-black/10 xl:pl-8">
          <div class="space-y-8">
            <section>
              <h2 class="text-[0.92rem] font-semibold uppercase tracking-[0.08em] text-primary">
                {authorSectionLabel}
              </h2>
              <div class="mt-4 border-t border-black/10 pt-4">
                <div class="grid gap-4">
                  {publicationAuthors.map((author) => (
                    <div class="flex items-start gap-4">
                      <img
                        src={author.image}
                        alt={author.name}
                        class:list={[
                          "h-20 w-20 shrink-0",
                          isDefaultProfileImage(author.image)
                            ? "border border-black/10 bg-[#eef2ef] object-contain p-2.5 opacity-75"
                            : "object-cover",
                        ]}
                      />
                      <div class="min-w-0">
                        <p class="text-[1.4rem] font-semibold leading-tight text-primary">
                          {author.href ? (
                            <a href={author.href} class="transition-colors hover:text-hover">
                              {author.name}
                            </a>
                          ) : (
                            author.name
                          )}
                        </p>
                        {author.role && (
                          <p class="mt-2 text-[1rem] leading-7 text-primary/72">
                            {author.role}
                          </p>
                        )}
                      </div>
                    </div>
                  ))}
                  </div>
              </div>
            </section>

            {publication.contributors.length > 0 && (
              <section class="border-t border-black/10 pt-6">
                <h2 class="text-[0.92rem] font-semibold uppercase tracking-[0.08em] text-primary">
                  People involved
                </h2>
                <div class="mt-5 grid gap-3">
                  {publication.contributors.map((person) => (
                    <div class="border border-black/10 px-3 py-3">
                      {person.href ? (
                        <a href={person.href} class="group flex items-center gap-3">
                          <img
                            src={person.image || DEFAULT_PROFILE_IMAGE}
                            alt={person.name}
                            class:list={[
                              "h-10 w-10 shrink-0 transition",
                              isDefaultProfileImage(person.image)
                                ? "border border-black/10 bg-[#eef2ef] object-contain p-1 opacity-75"
                                : "object-cover",
                            ]}
                          />
                          <div class="min-w-0">
                            <p class="text-[0.9rem] font-medium leading-tight text-primary transition-colors group-hover:text-hover">
                              {person.name}
                            </p>
                            {person.role && (
                              <p class="mt-1 text-[0.75rem] leading-5 text-primary/58">
                                {person.role}
                              </p>
                            )}
                          </div>
                        </a>
                      ) : (
                        <div class="flex items-center gap-3">
                          <img
                            src={person.image || DEFAULT_PROFILE_IMAGE}
                            alt={person.name}
                            class:list={[
                              "h-10 w-10 shrink-0",
                              isDefaultProfileImage(person.image)
                                ? "border border-black/10 bg-[#eef2ef] object-contain p-1 opacity-75"
                                : "object-cover",
                            ]}
                          />
                          <p class="text-[0.9rem] font-medium leading-tight text-primary">
                            {person.name}
                          </p>
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </section>
            )}

            {publication.relatedProjects.length > 0 && (
              <section class="border-t border-black/10 pt-6">
                <h2 class="text-[0.92rem] font-semibold uppercase tracking-[0.08em] text-primary">
                  Project
                </h2>
                <div class="mt-5 grid gap-3">
                  <p class="text-[0.82rem] font-semibold uppercase tracking-[0.08em] text-primary/55">
                    {relatedProjectsLeadLabel}
                  </p>
                  {publication.relatedProjects.map((project) => (
                    <a
                      href={project.href}
                      class="block border px-4 py-4 transition-transform duration-200 hover:-translate-y-0.5"
                      style={`border-color:${project.color};background:${project.color};color:${getProjectButtonTextColor(project.color)};`}
                    >
                      <p class="text-[1rem] font-semibold leading-tight">
                        {project.title} Project
                      </p>
                    </a>
                  ))}
                </div>
              </section>
            )}

            <section class="border-t border-black/10 pt-6">
              <h2 class="text-[0.92rem] font-semibold uppercase tracking-[0.08em] text-primary">
                Publication
              </h2>
              <div class="mt-5 space-y-4">
                <p class="text-[2rem] font-semibold leading-none tracking-[-0.03em] text-primary">
                  {formattedDate}
                </p>
                <p class="text-[0.85rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
                  {publication.outputType}
                </p>
                {publication.hashtags.length > 0 && (
                  <div class="flex flex-wrap gap-x-3 gap-y-2 text-[1rem] italic leading-7 text-primary/72">
                    {publication.hashtags.map((tag) => (
                      <a
                        href={`/blog/tags/${encodeURIComponent(tag.slug)}`}
                        class="transition-colors hover:text-hover"
                      >
                        #{tag.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </section>

            <section class="hidden border-t border-black/10 pt-6 xl:block">
              <div class="grid gap-3">
                {sidebarActions.map((action) => (
                  <a
                    href={action.href}
                    target={action.target}
                    rel={action.rel}
                    download={action.download}
                    class="inline-flex items-center justify-between border border-black/12 px-5 py-4 text-[0.95rem] font-semibold uppercase tracking-[0.08em] text-primary transition-colors hover:border-black hover:text-hover"
                  >
                    <span class="flex min-w-0 flex-col items-start gap-1">
                      <span>{action.label}</span>
                      {action.downloadCountApiHref && (
                        <span
                          data-download-count
                          data-download-count-endpoint={action.downloadCountApiHref}
                          hidden
                          class="text-[0.72rem] font-medium normal-case tracking-normal text-primary/58"
                        ></span>
                      )}
                    </span>
                    <Icon
                      name={`lucide:${action.icon}`}
                      class="h-4 w-4"
                    />
                  </a>
                ))}
              </div>
            </section>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {similarPublications.length > 0 && (
    <RelatedPublicationSlider
      items={similarPublications}
      title="Related Topics"
      subtitle="Other publications connected through overlapping hashtags."
    />
  )}
  {downloadCountApiHref && (
    <script is:inline define:vars={{ downloadCountApiHref }}>
      const formatDownloadCount = (count) =>
        count === 1 ? "1 download" : `${count} downloads`;

      const syncDownloadCounts = () => {
        const countNodes = Array.from(
          document.querySelectorAll("[data-download-count]"),
        );

        if (!countNodes.length) {
          return;
        }

        fetch(downloadCountApiHref, {
          headers: {
            Accept: "application/json",
          },
        })
          .then((response) => (response.ok ? response.json() : null))
          .then((payload) => {
            if (!payload || typeof payload.downloadCount !== "number") {
              return;
            }

            countNodes.forEach((node) => {
              if (!(node instanceof HTMLElement)) {
                return;
              }

              node.textContent = formatDownloadCount(payload.downloadCount);
              node.hidden = false;
            });
          })
          .catch(() => {});
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", syncDownloadCounts, {
          once: true,
        });
      } else {
        syncDownloadCounts();
      }

      document.addEventListener("astro:after-swap", syncDownloadCounts);
    </script>
  )}
</BaseLayout>

<style is:inline>
  .publication-prose > h1:first-child {
    display: none;
  }

  .publication-prose :is(h2, h3, h4) {
    margin-top: 2.5rem;
    color: #0a1220;
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .publication-prose p {
    margin-top: 1.1rem;
  }

  .publication-prose ul,
  .publication-prose ol {
    margin-top: 1.25rem;
    padding-left: 1.3rem;
  }

  .publication-prose li + li {
    margin-top: 0.45rem;
  }

  .publication-prose a {
    color: #15243a;
    text-decoration: underline;
    text-decoration-color: rgba(21, 36, 58, 0.24);
    text-underline-offset: 0.22em;
  }
</style>
