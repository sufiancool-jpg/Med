---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Headline from "../../../components/ui/Headline.astro";
import { getOutputTypePaths, getPublicationsByOutputTypeSlug } from "../../../lib/site-data";

export async function getStaticPaths() {
  const outputTypes = await getOutputTypePaths();

  return Promise.all(
    outputTypes.map(async ({ slug, label }) => ({
      params: { category: slug },
      props: {
        label,
        posts: await getPublicationsByOutputTypeSlug(slug),
      },
    })),
  );
}

const { label, posts } = Astro.props;

const metadata = {
  title: `Category: ${label}`,
  description: `Publications in the ${label} category.`,
};
---

<BaseLayout metadata={metadata}>
  <section class="relative px-4 py-24 sm:px-6 lg:px-8 md:py-32">
    <div class="relative mx-auto max-w-5xl">
      <Headline
        tagline="Category"
        title={label}
        subtitle={`Showing ${posts.length} publication${posts.length === 1 ? "" : "s"}.`}
        classes={{
          container: "mb-12 text-center",
          title:
            "font-heading mb-4 text-4xl font-bold tracking-tight text-foreground md:text-6xl capitalized",
          subtitle: "mx-auto max-w-3xl text-xl text-muted-foreground",
        }}
      />

      <div class="mb-8 text-center">
        <a href="/blog" class="text-primary hover:underline">← Back to publications</a>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="border border-black/10 bg-white p-5">
            <a href={post.href} class="block">
              <img
                src={post.image ?? "/blog/welcome.webp"}
                alt={post.title}
                class="aspect-[4/3] w-full object-cover"
                loading="lazy"
              />
              <p class="mt-4 text-[0.72rem] font-semibold uppercase tracking-[0.1em] text-primary/55">
                {new Intl.DateTimeFormat("en-US", {
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                }).format(post.pubDate)}
              </p>
              <h2 class="mt-2 text-xl font-semibold leading-tight text-primary">
                {post.title}
              </h2>
              <p class="mt-3 text-sm leading-7 text-primary/72">{post.description}</p>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
