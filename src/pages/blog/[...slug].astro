---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/seo/Schema.astro";
import AudioPreviewPlayer from "../../components/widgets/AudioPreviewPlayer.astro";
import { Icon } from "astro-icon/components";
import { render } from "astro:content";
import {
  DEFAULT_PROFILE_IMAGE,
  getPublicationBySlug,
  getPublications,
  isDefaultProfileImage,
} from "../../lib/site-data";

export async function getStaticPaths() {
  const publications = await getPublications();

  return publications.map((publication) => ({
    params: { slug: publication.slug },
  }));
}

const slug = Astro.params.slug ?? "";
const publication = await getPublicationBySlug(slug);

if (!publication) {
  throw new Error(`Publication not found for slug "${slug}"`);
}

let LocalContent = undefined;
let readingTime = "";

if (publication.source === "local") {
  const { Content, remarkPluginFrontmatter } = await render(publication.localEntry);
  LocalContent = Content;
  readingTime = remarkPluginFrontmatter?.minutesRead
    ? `${Math.ceil(remarkPluginFrontmatter.minutesRead)} min read`
    : "";
}

const formattedDate = publication.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const resolvedAuthorRole = publication.authorRole || `${publication.outputType} contributor`;
const isPodcast = publication.outputTypeSlug === "pod-cast";
const podcastAudioHref = publication.audioHref || (isPodcast ? publication.downloadHref : undefined);
const fileDownloadHref =
  publication.downloadHref && publication.downloadHref !== podcastAudioHref
    ? publication.downloadHref
    : undefined;
const resolvedDownloadLabel =
  publication.downloadLabel ||
  (fileDownloadHref?.toLowerCase().endsWith(".pdf")
    ? "Download PDF"
    : "Download publication");
const authorProfileHref = publication.authorPerson?.href;

const metadata = {
  title: publication.title,
  description: publication.description,
  ogImage: publication.image,
};
---

<BaseLayout metadata={metadata}>
  <Schema
    type="BlogPosting"
    data={{
      title: publication.title,
      description: publication.description,
      image: publication.image,
      pubDate: publication.pubDate,
      author: publication.author,
      url: Astro.url.href,
    }}
  />

  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 md:py-10 lg:px-8">
      <div class="grid gap-10 xl:grid-cols-[minmax(0,1.55fr)_21rem] xl:items-start">
        <article>
          <div class="max-w-5xl">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.82rem] font-semibold uppercase tracking-[0.12em] text-primary/60">
              <a
                href={`/blog/category/${encodeURIComponent(publication.outputTypeSlug)}`}
                class="transition-colors hover:text-hover"
              >
                {publication.outputType}
              </a>
              <span aria-hidden="true" class="text-primary/35">/</span>
              <span>{formattedDate}</span>
              {readingTime && (
                <>
                  <span aria-hidden="true" class="text-primary/35">/</span>
                  <span>{readingTime}</span>
                </>
              )}
            </div>

            <h1 class="mt-4 text-[clamp(1.4rem,3.5vw,2.9rem)] font-bold leading-[0.96] tracking-[-0.035em] text-primary">
              {publication.title}
            </h1>

            <p class="mt-5 max-w-4xl text-[1.05rem] italic leading-8 text-primary/74 md:text-[1.18rem]">
              {publication.description}
            </p>

            {!isPodcast && publication.downloadHref && (
              <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 text-[0.98rem] italic text-primary/78">
                <span>To access the full publication, use the publication file here</span>
                <a
                  href={publication.downloadHref}
                  target="_blank"
                  rel="noreferrer"
                  class="font-semibold not-italic text-hover transition-colors hover:text-primary"
                >
                  {resolvedDownloadLabel}
                </a>
              </div>
            )}

            {isPodcast && podcastAudioHref && (
              <AudioPreviewPlayer
                id="podcast-player"
                audioSrc={podcastAudioHref}
                title={publication.title}
                initialDuration="00:24"
                containerClass="mt-6 max-w-4xl"
              />
            )}
          </div>

          {publication.image && (
            <div class="mt-8 overflow-hidden border border-black/12 bg-white">
              <img
                src={publication.image}
                alt={publication.title}
                class="aspect-[5/4] w-full object-cover"
              />
            </div>
          )}

          <div
            id="publication-body"
            class="publication-prose mt-10 max-w-none text-[1rem] leading-8 text-primary/78"
          >
            {publication.source === "wordpress" ? (
              <Fragment set:html={publication.contentHtml}></Fragment>
            ) : (
              LocalContent && <LocalContent />
            )}
          </div>
        </article>

        <aside class="xl:sticky xl:top-[calc(var(--nav-h,72px)+2rem)] xl:border-l xl:border-black/10 xl:pl-8">
          <div class="space-y-8">
            <section>
              <h2 class="text-[0.92rem] font-semibold uppercase tracking-[0.08em] text-primary">
                Author
              </h2>
              <div class="mt-4 border-t border-black/10 pt-4">
                <div class="flex items-start gap-4">
                  <img
                    src={publication.authorImage || DEFAULT_PROFILE_IMAGE}
                    alt={publication.author}
                    class:list={[
                      "h-20 w-20 shrink-0",
                      isDefaultProfileImage(publication.authorImage)
                        ? "border border-black/10 bg-[#eef2ef] object-contain p-2.5 grayscale opacity-75"
                        : "object-cover grayscale",
                    ]}
                  />
                  <div class="min-w-0">
                    <p class="text-[1.4rem] font-semibold leading-tight text-primary">
                      {authorProfileHref ? (
                        <a href={authorProfileHref} class="transition-colors hover:text-hover">
                          {publication.author}
                        </a>
                      ) : (
                        publication.author
                      )}
                    </p>
                    <p class="mt-2 text-[1rem] leading-7 text-primary/72">
                      {resolvedAuthorRole}
                    </p>
                  </div>
                </div>
              </div>
            </section>

            {publication.contributors.length > 0 && (
              <section class="border-t border-black/10 pt-6">
                <h2 class="text-[0.92rem] font-semibold uppercase tracking-[0.08em] text-primary">
                  People involved
                </h2>
                <div class="mt-5 grid gap-3">
                  {publication.contributors.map((person) => (
                    <div class="border border-black/10 px-3 py-3">
                      {person.href ? (
                        <a href={person.href} class="group flex items-center gap-3">
                          <img
                            src={person.image || DEFAULT_PROFILE_IMAGE}
                            alt={person.name}
                            class:list={[
                              "h-10 w-10 shrink-0 transition",
                              isDefaultProfileImage(person.image)
                                ? "border border-black/10 bg-[#eef2ef] object-contain p-1 grayscale opacity-75"
                                : "object-cover grayscale group-hover:grayscale-0",
                            ]}
                          />
                          <div class="min-w-0">
                            <p class="text-[0.9rem] font-medium leading-tight text-primary transition-colors group-hover:text-hover">
                              {person.name}
                            </p>
                            {person.role && (
                              <p class="mt-1 text-[0.75rem] leading-5 text-primary/58">
                                {person.role}
                              </p>
                            )}
                          </div>
                        </a>
                      ) : (
                        <div class="flex items-center gap-3">
                          <img
                            src={person.image || DEFAULT_PROFILE_IMAGE}
                            alt={person.name}
                            class:list={[
                              "h-10 w-10 shrink-0",
                              isDefaultProfileImage(person.image)
                                ? "border border-black/10 bg-[#eef2ef] object-contain p-1 grayscale opacity-75"
                                : "object-cover grayscale",
                            ]}
                          />
                          <p class="text-[0.9rem] font-medium leading-tight text-primary">
                            {person.name}
                          </p>
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </section>
            )}

            <section class="border-t border-black/10 pt-6">
              <h2 class="text-[0.92rem] font-semibold uppercase tracking-[0.08em] text-primary">
                Publication
              </h2>
              <div class="mt-5 space-y-4">
                <p class="text-[2rem] font-semibold leading-none tracking-[-0.03em] text-primary">
                  {formattedDate}
                </p>
                <p class="text-[0.85rem] font-semibold uppercase tracking-[0.12em] text-primary/55">
                  {publication.outputType}
                </p>
                {publication.hashtags.length > 0 && (
                  <div class="flex flex-wrap gap-x-3 gap-y-2 text-[1rem] italic leading-7 text-primary/72">
                    {publication.hashtags.map((tag) => (
                      <a
                        href={`/blog/tags/${encodeURIComponent(tag.slug)}`}
                        class="transition-colors hover:text-hover"
                      >
                        #{tag.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </section>

            <section class="border-t border-black/10 pt-6">
              <div class="grid gap-3">
                {isPodcast && podcastAudioHref && (
                  <a
                    href="#podcast-player"
                    class="inline-flex items-center justify-between border border-black/12 px-5 py-4 text-[0.95rem] font-semibold uppercase tracking-[0.08em] text-primary transition-colors hover:border-black hover:text-hover"
                  >
                    <span>Listen to episode</span>
                    <Icon name="lucide:arrow-down-right" class="h-4 w-4" />
                  </a>
                )}
                {!isPodcast && publication.downloadHref && (
                  <a
                    href={publication.downloadHref}
                    target="_blank"
                    rel="noreferrer"
                    download
                    class="inline-flex items-center justify-between border border-black/12 px-5 py-4 text-[0.95rem] font-semibold uppercase tracking-[0.08em] text-primary transition-colors hover:border-black hover:text-hover"
                  >
                    <span>{resolvedDownloadLabel}</span>
                    <Icon name="lucide:download" class="h-4 w-4" />
                  </a>
                )}
                {!isPodcast && !publication.downloadHref && (
                  <a
                    href="#publication-body"
                    class="inline-flex items-center justify-between border border-black/12 px-5 py-4 text-[0.95rem] font-semibold uppercase tracking-[0.08em] text-primary transition-colors hover:border-black hover:text-hover"
                  >
                    <span>View publication</span>
                    <Icon name="lucide:arrow-down-right" class="h-4 w-4" />
                  </a>
                )}
                {fileDownloadHref && (
                  <a
                    href={fileDownloadHref}
                    target="_blank"
                    rel="noreferrer"
                    download
                    class="inline-flex items-center justify-between border border-black/12 px-5 py-4 text-[0.95rem] font-semibold uppercase tracking-[0.08em] text-primary transition-colors hover:border-black hover:text-hover"
                  >
                    <span>{resolvedDownloadLabel}</span>
                    <Icon name="lucide:download" class="h-4 w-4" />
                  </a>
                )}
              </div>
            </section>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:inline>
  .publication-prose > h1:first-child {
    display: none;
  }

  .publication-prose :is(h2, h3, h4) {
    margin-top: 2.5rem;
    color: #0a1220;
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .publication-prose p {
    margin-top: 1.1rem;
  }

  .publication-prose ul,
  .publication-prose ol {
    margin-top: 1.25rem;
    padding-left: 1.3rem;
  }

  .publication-prose li + li {
    margin-top: 0.45rem;
  }

  .publication-prose a {
    color: #15243a;
    text-decoration: underline;
    text-decoration-color: rgba(21, 36, 58, 0.24);
    text-underline-offset: 0.22em;
  }
</style>
