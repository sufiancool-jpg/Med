---
import BaseLayout from "../layouts/BaseLayout.astro";
import Content from "../components/widgets/Content.astro";
import Form from "../components/ui/Form.astro";

const metadata = {
  title: "Contact",
  description:
    "Get in touch regarding research partnerships, project collaboration, volunteering, and general information.",
};

const contactText = [
  "Contact the team for research partnerships, project collaboration, volunteering, and general information.",
];
---

<BaseLayout {metadata}>
  <Content tagline="Contact" title="Contact" description={contactText} />
  <div
    class="reveal mx-auto mb-12 max-w-xl border border-border bg-card p-8 shadow-sm md:mb-16"
  >
    <Form recipient="i.bertocchini@mediplatform.org" />
  </div>
</BaseLayout>
