---
import BaseLayout from "../layouts/BaseLayout.astro";
import Content from "../components/widgets/Content.astro";
import Features from "../components/widgets/Features.astro";
import ServiceList from "../components/widgets/ServiceList.astro";

const eventTypes = [
  {
    title: "Events",
    description: "Public events focused on policy dialogue and regional cooperation.",
    icon: "lucide:calendar-days",
  },
  {
    title: "Mediterranean Talks",
    description: "In-conversation sessions with experts on strategic Mediterranean issues.",
    icon: "lucide:messages-square",
  },
  {
    title: "African Talks",
    description: "Dialogue sessions on African policy priorities and multilateral dynamics.",
    icon: "lucide:globe-2",
  },
];

const metadata = {
  title: "Events",
  description:
    "Events listings including Mediterranean Talks, African Talks, roundtables, and public lectures.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Content
    tagline="Events"
    title="Events and Talks"
    description={[
      "Listings include Events, Mediterranean Talks, African Talks, Book Presentation, Roundtable, and Public Lecture formats.",
    ]}
  />

  <ServiceList services={eventTypes} classes={{ container: "pt-0 md:pt-0" }} />

  <Features
    tagline="Recent examples"
    title="Selected Event Topics"
    subtitle="Illustrative event themes from current listings."
    features={[
      {
        title:
          "The Role of Tuareg and Fulani Nomadic Communities and Elites in the Sahel Conflicts",
        description: "Event format focused on conflict dynamics and regional stabilization.",
        icon: "lucide:book-open",
      },
      {
        title: "Russian Power Practices and Repertoires",
        description: "Conference-style dialogue on geopolitical practices and strategic repertoires.",
        icon: "lucide:shield",
      },
      {
        title: "Potential of Reconfigured Value Chains in Mediterranean Cooperation",
        description: "Public discussion on strategic autonomy and regional economic transformation.",
        icon: "lucide:chart-no-axes-combined",
      },
    ]}
  />
</BaseLayout>
