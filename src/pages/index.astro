---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import { getCollection } from "astro:content";
import HeroArticleSlider from "../components/widgets/HeroArticleSlider.astro";

const toHashtag = (value: string) =>
  `#${value
    .toLowerCase()
    .replace(/[^\w\s-]/g, "")
    .trim()
    .replace(/\s+/g, "")}`;

const featuredPublications = [
  {
    type: "E-Book",
    title: "The Red Sea: Divided by Water, United by Opportunities",
    authors: "Ghanem, Narbone, Palleschi, and Maru (ed.)",
    date: "Feb 25, 2026",
    excerpt:
      "A multi-disciplinary publication on regional opportunity structures, cooperation pathways, and strategic dialogue.",
    href: "#",
    thumbnail: "/articles/red-sea-ebook.pdf.png",
    thumbnailAlt: "The Red Sea publication cover",
    tags: ["#RedSea", "#RegionalCooperation", "#PolicyDialogue"],
  },
  {
    type: "Policy Paper",
    title: "Distribution of Powers in Libya’s Future Local Governance System",
    authors: "Intissar Kherigi",
    date: "Feb 5, 2026",
    excerpt:
      "Policy paper on governance architecture and local institutional design for stability and inclusive policymaking.",
    href: "#",
    thumbnail: "/blog/blog_post_10_1768850582328.webp",
    thumbnailAlt: "Publication thumbnail placeholder for local governance policy paper",
    tags: ["#Libya", "#LocalGovernance", "#InstitutionalDesign"],
  },
  {
    type: "Policy Paper",
    title:
      "Subnational Governance in Divided Societies: Learning from Yemen to Inform Libya’s Peace Process",
    authors: "Mohamed Aziz Mrad",
    date: "Jan 8, 2026",
    excerpt:
      "Comparative insights connecting local governance, peace process design, and practical dialogue support.",
    href: "#",
    thumbnail: "/blog/blog_post_11_1768850597259.webp",
    thumbnailAlt: "Publication thumbnail placeholder for subnational governance policy paper",
    tags: ["#SubnationalGovernance", "#Yemen", "#PeaceProcess"],
  },
  {
    type: "Policy Paper",
    title:
      "Youth as Catalysts for Shaping Libya’s Future Pathways for Inclusion in National Dialogue and Vision-Making",
    authors: "Abdelkarim Skouri",
    date: "Dec 2, 2025",
    excerpt:
      "Evidence-led paper on youth inclusion, national dialogue, and long-term vision-making processes.",
    href: "#",
    thumbnail: "/blog/blog_post_12_1768850610966.webp",
    thumbnailAlt: "Publication thumbnail placeholder for youth inclusion policy paper",
    tags: ["#YouthInclusion", "#NationalDialogue", "#VisionMaking"],
  },
];

const activityThemes = [
  {
    title: "Libya Platform",
    summary:
      "Multi-track initiative combining field-based research, capacity building, and dialogue support.",
    meta: "Project",
    href: "/services/libya-platform",
    hoverBg: "#15243a",
    hoverTitle: "#ffffff",
    hoverMeta: "rgba(255,255,255,0.76)",
    hoverSummary: "rgba(255,255,255,0.88)",
  },
  {
    title: "Africa Nexus",
    summary:
      "Policy analyses and crossroads exchanges to strengthen African-European knowledge ecosystems.",
    meta: "Project",
    href: "/services/africa-nexus",
    hoverBg: "#42b09a",
    hoverTitle: "#ffffff",
    hoverMeta: "rgba(255,255,255,0.76)",
    hoverSummary: "rgba(255,255,255,0.88)",
  },
  {
    title: "Gulf Platform",
    summary:
      "Research and dialogue on Europe-Gulf relations, societal trends, and sectoral cooperation.",
    meta: "Project",
    href: "/services/gulf-platform",
    hoverBg: "#8c6335",
    hoverTitle: "#ffffff",
    hoverMeta: "rgba(255,255,255,0.76)",
    hoverSummary: "rgba(255,255,255,0.88)",
  },
];

const fillerImages = [
  "/blog/blog_post_1_1768848683359.webp",
  "/blog/blog_post_5_1768848750922.webp",
  "/blog/blog_post_8_1768850554501.webp",
  "/blog/blog_post_11_1768850597259.webp",
  "/blog/blog_post_12_1768850610966.webp",
];

const formatBlogDate = (date: Date) =>
  new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(date);

const blogEntries = await getCollection("blog");
const sortedBlogEntries = blogEntries
  .filter((post) => post.data && post.data.pubDate)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const heroSliderItems = sortedBlogEntries.map((post, index) => ({
  title: post.data.title,
  href: `/blog/${post.id}`,
  excerpt: post.data.description,
  author: post.data.author,
  date: formatBlogDate(post.data.pubDate),
  category: post.data.category ?? "Publication",
  image: post.data.image || fillerImages[index % fillerImages.length],
  hashtags: (post.data.tags ?? [])
    .slice(0, 3)
    .map((tag) => toHashtag(tag.replace(/-/g, " ")))
    .join(" "),
}));

const landingIntro = {
  firstRest:
    "is a research, dialogue, and educational initiative dedicated to examining the region's evolving political, socio-economic, and security dynamics. We provide a space for collective reflection on Mediterranean transformations, foster informed debate, and support evidence-based policymaking across national and transnational levels.",
  second:
    "Our work spans regional geopolitics and diplomacy, the political economy of natural resources, energy transition, climate change, and long-term scenario building.",
};
const joinNetworkText = "Join the network";
const audioRelease = {
  type: "Audio release",
  series: "Mediterranean Platform Audio Brief",
  title: "Red Sea Corridors: Trade, Security, and Regional Power",
  summary:
    "A mock preview episode unpacking the strategic significance of the Red Sea and the regional actors shaping its future.",
  duration: "00:24",
  date: "New episode",
  href: "/blog/red-sea-corridors-audio-brief",
  ctaText: "Open release page",
  audioSrc: "/audio/mock-red-sea-brief.mp3",
};
const featuredArticle = {
  title: "The Red Sea: Divided by Water, United by Opportunities",
  editors:
    "Edited by Dr. Dalia Ghanem, Luigi Narbone, Mehari Taddele Maru & Carlo Palleschi.",
  paragraphs: [
    "The recent maritime crisis in the Red Sea has brought this vital global waterway back to the fore. But the region’s destiny is no longer being decided by the distant chess moves of great powers; it is being shaped, right now, by the assertive and competing interests of regional middle powers. Middle Eastern countries (MECs), such as the United Arab Emirates, Saudi Arabia, Qatar and Türkiye, actively rewriting the security and political map of the Red Sea and the Horn of Africa (HoA) with a mix of money, diplomacy, and direct military and other forms of intervention. At the same time, the HoA is no longer a passive recipient of MECs’ engagement. Its governments, elites, and local actors have learned to navigate and exploit MECs’ ambitions, using external competition to bolster domestic legitimacy, attract investment, and diversify partnerships.",
    "To understand this critical corridor this book provides the first comprehensive analysis that breaks down the silos between MECs and the HoA. This volume critically examines the interactions between the MECs and the HoA and seeks to align visions and identify concrete steps toward realizing the vision of a Red Sea that, though divided by waters, is united by opportunities.",
    "Co-published by the Middle East Council on Global Affairs, the Mediterranean Platform, and the Pan-African Agenda Institute, this eBook provides the first comprehensive analysis that breaks down the silos between Middle Eastern countries (MECs) and the Horn of Africa (HoA). By bringing perspectives from the Gulf into direct conversation with those from the Horn, it critically examines the interactions between the MECs and the HoA.",
  ],
};

const metadata = {
  title: `${siteConfig.name} — Research, Dialogue, and Policy Analysis`,
  description:
    "Editorial homepage focused on policy-relevant publications, activity platforms, and current regional analysis.",
  ignoreTitleTemplate: true,
};
const midPageSliderItems = heroSliderItems.slice(0, 3);
---

<BaseLayout {metadata}>
  <section
    data-hero-section
    class="flex [height:var(--section-h,calc(100svh-112px))] flex-col"
  >
    <div class="flex h-full w-full min-h-0 flex-col overflow-hidden">
      <div
        data-hero-intro-panel
        class="w-full shrink-0 overflow-hidden [transition-property:max-height,transform,opacity] duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] will-change-[max-height,transform,opacity]"
      >
        <div class="border-b border-black bg-white px-4 pt-3.5 pb-2.5 sm:px-6 md:pt-4 md:pb-2.5 lg:px-8">
          <div class="grid items-start gap-3.5 md:grid-cols-[62%_38%] md:gap-0">
            <div class="w-full md:pr-5">
              <p class="text-left text-[0.86rem] font-semibold leading-[1.55] text-primary md:text-[0.9rem]">
                <span class="italic">The Mediterranean Platform</span> {landingIntro.firstRest}
              </p>
              <p class="mt-1.5 text-left text-[0.86rem] font-semibold leading-[1.55] text-primary md:text-[0.9rem]">
                {landingIntro.second}
              </p>
              <a
                href="/about"
                class="mt-2.5 inline-flex cursor-pointer items-center gap-2 text-left text-[0.92rem] font-semibold tracking-[0.04em] text-primary transition-colors hover:text-hover"
              >
                <span>About us</span>
                <svg
                  viewBox="0 0 20 12"
                  class="h-3 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M1 6h14"></path>
                  <path d="m11 2 4 4-4 4"></path>
                </svg>
              </a>
            </div>
            <div class="w-full md:border-l md:border-black md:pl-5">
              <div class="group relative flex h-full w-full items-center justify-end">
                <div class="relative ml-auto w-[85%] max-w-[425px] aspect-[235/76]">
                  <img
                    src="/Logo3.png"
                    alt="Mediterranean Platform"
                    class="absolute inset-0 h-full w-full -translate-x-[3%] object-contain transition-opacity duration-200 group-hover:opacity-0"
                  />
                  <p class="pointer-events-none absolute inset-0 flex items-center justify-end text-right text-[clamp(1.7rem,4.45vw,3.85rem)] font-bold uppercase leading-[0.9] tracking-tight text-[#70c8e0] opacity-0 transition-opacity duration-200 group-hover:opacity-100">
                    {joinNetworkText}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div data-hero-video-panel class="relative flex-1 min-h-0 overflow-hidden bg-black">
        <video
          data-landing-video
          class="absolute inset-0 h-full w-full object-cover"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
        >
          <source src="/webbg.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-black/10"></div>
      </div>
    </div>

  </section>

  <script is:inline>
    const initLandingVideos = () => {
      document.querySelectorAll("[data-landing-video]").forEach((video) => {
        video.muted = true;
        video.defaultMuted = true;
        const playPromise = video.play?.();
        if (playPromise && typeof playPromise.catch === "function") {
          playPromise.catch(() => {});
        }
      });
    };

    const initAudioPreviewPlayers = () => {
      const formatTime = (value) => {
        const totalSeconds = Number.isFinite(value) ? Math.max(0, Math.floor(value)) : 0;
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;
        return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
      };

      document.querySelectorAll("[data-audio-preview]").forEach((player) => {
        if (!(player instanceof HTMLElement) || player.dataset.bound === "true") return;

        const audio = player.querySelector("[data-audio-el]");
        const toggle = player.querySelector("[data-audio-toggle]");
        const playIcon = player.querySelector("[data-audio-icon-play]");
        const pauseIcon = player.querySelector("[data-audio-icon-pause]");
        const progressFill = player.querySelector("[data-audio-progress-fill]");
        const progressRail = player.querySelector("[data-audio-progress-rail]");
        const currentTime = player.querySelector("[data-audio-current]");
        const durationTime = player.querySelector("[data-audio-duration]");
        const waveBars = Array.from(player.querySelectorAll("[data-audio-wave-bar]"));

        if (
          !(audio instanceof HTMLAudioElement) ||
          !(toggle instanceof HTMLButtonElement) ||
          !(progressFill instanceof HTMLElement) ||
          !(progressRail instanceof HTMLElement)
        ) {
          return;
        }

        player.dataset.bound = "true";

        const syncUI = () => {
          const duration = audio.duration || 0;
          const current = audio.currentTime || 0;
          const progress = duration > 0 ? current / duration : 0;
          const activeBars = Math.round(progress * waveBars.length);

          progressFill.style.width = `${progress * 100}%`;

          if (currentTime instanceof HTMLElement) {
            currentTime.textContent = formatTime(current);
          }

          if (durationTime instanceof HTMLElement) {
            durationTime.textContent = formatTime(duration || 24);
          }

          if (playIcon instanceof HTMLElement) {
            playIcon.classList.toggle("hidden", !audio.paused);
          }

          if (pauseIcon instanceof HTMLElement) {
            pauseIcon.classList.toggle("hidden", audio.paused);
          }

          toggle.setAttribute(
            "aria-label",
            audio.paused ? "Play audio preview" : "Pause audio preview",
          );

          waveBars.forEach((bar, index) => {
            bar.classList.toggle("bg-[#42b09a]", index < activeBars);
            bar.classList.toggle("bg-primary/12", index >= activeBars);
          });
        };

        toggle.addEventListener("click", () => {
          if (audio.paused) {
            audio.play().catch(() => {});
          } else {
            audio.pause();
          }
        });

        progressRail.addEventListener("click", (event) => {
          const rect = progressRail.getBoundingClientRect();
          if (rect.width <= 0 || !audio.duration) return;
          const clickX = event.clientX - rect.left;
          const ratio = Math.max(0, Math.min(1, clickX / rect.width));
          audio.currentTime = ratio * audio.duration;
          syncUI();
        });

        audio.addEventListener("loadedmetadata", syncUI);
        audio.addEventListener("timeupdate", syncUI);
        audio.addEventListener("play", syncUI);
        audio.addEventListener("pause", syncUI);
        audio.addEventListener("ended", () => {
          audio.currentTime = 0;
          syncUI();
        });

        syncUI();
      });
    };

    const initHomeEnhancements = () => {
      initLandingVideos();
      initAudioPreviewPlayers();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHomeEnhancements, {
        once: true,
      });
    } else {
      initHomeEnhancements();
    }

    document.addEventListener("astro:after-swap", initHomeEnhancements);
  </script>
  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const articleTriggerIdPrefix = "article-section-highlight-";
    const articleWindow = window as Window & {
      __lenis?: { on?: (_event: string, _cb: () => void) => void };
      __articleLenisBridgeBound?: boolean;
      __articleHighlightCleanup?: (() => void) | null;
      __articleHighlightDisabled?: boolean;
    };

    const clearArticleTriggers = () => {
      ScrollTrigger.getAll().forEach((trigger) => {
        const triggerId = trigger.vars.id;
        if (
          typeof triggerId === "string" &&
          triggerId.startsWith(articleTriggerIdPrefix)
        ) {
          trigger.kill();
        }
      });
    };

    const ensureLenisScrollBridge = () => {
      if (articleWindow.__articleLenisBridgeBound) return;

      const tryBind = () => {
        const lenis = articleWindow.__lenis;
        if (!lenis || typeof lenis.on !== "function") return false;
        lenis.on("scroll", () => ScrollTrigger.update());
        articleWindow.__articleLenisBridgeBound = true;
        return true;
      };

      if (tryBind()) return;

      let attempts = 0;
      const retry = () => {
        attempts += 1;
        if (tryBind() || attempts > 180) return;
        window.requestAnimationFrame(retry);
      };

      window.requestAnimationFrame(retry);
    };

    const wrapWordsForHighlight = (paragraph: HTMLElement) => {
      const rawText = paragraph.textContent?.replace(/\s+/g, " ").trim() ?? "";
      if (!rawText) return [];

      const words = rawText.split(" ").filter(Boolean);
      paragraph.textContent = "";

      words.forEach((word, index) => {
        const span = document.createElement("span");
        span.dataset.readingWord = "true";
        span.className = "inline";
        span.textContent = word;
        paragraph.append(span);

        if (index < words.length - 1) {
          const spacer = document.createElement("span");
          spacer.dataset.readingSpacer = "true";
          spacer.className = "inline";
          spacer.textContent = " ";
          spacer.style.whiteSpace = "pre-wrap";
          paragraph.append(spacer);
        }
      });

      paragraph.dataset.wordsWrapped = "true";
      return Array.from(paragraph.querySelectorAll<HTMLElement>("[data-reading-word]"));
    };

    const setReadingSegmentState = (segment: HTMLElement, isActive: boolean) => {
      segment.style.backgroundColor = isActive ? "#475569" : "transparent";
      segment.style.color = isActive ? "#f8fafc" : "#0a1220";
      segment.style.borderRadius = "0";
    };

    const setWordsByProgress = (words: HTMLElement[], progress: number) => {
      const clampedProgress = Math.max(0, Math.min(1, progress));
      const highlightedCount = Math.max(
        0,
        Math.min(words.length, Math.floor(clampedProgress * words.length)),
      );

      words.forEach((word, index) => {
        const isActive = index < highlightedCount;
        setReadingSegmentState(word, isActive);

        const spacer = word.nextElementSibling;
        if (
          spacer instanceof HTMLElement &&
          spacer.dataset.readingSpacer === "true"
        ) {
          setReadingSegmentState(spacer, isActive);
        }
      });
    };

    const calcArticleProgress = (title: HTMLElement, article: HTMLElement) => {
      const titleTop = title.getBoundingClientRect().top;
      const articleBottom = article.getBoundingClientRect().bottom;
      const startPx = window.innerHeight * 0.5;
      const endPx = window.innerHeight * 0.35;
      const span = Math.max(1, articleBottom - titleTop + (startPx - endPx));
      return (startPx - titleTop) / span;
    };

    const resetArticleHighlightStyles = (article: HTMLElement) => {
      const segments = Array.from(
        article.querySelectorAll<HTMLElement>(
          "[data-reading-word], [data-reading-spacer]",
        ),
      );
      segments.forEach((segment) => {
        segment.style.backgroundColor = "transparent";
        segment.style.color = "#0a1220";
        segment.style.borderRadius = "0";
        segment.style.paddingLeft = "0";
        segment.style.paddingRight = "0";
      });
    };

    const syncArticleToggleUI = () => {
      const toggle = document.querySelector("[data-highlight-toggle]");
      const label = document.querySelector("[data-highlight-toggle-label]");
      if (!(toggle instanceof HTMLButtonElement)) return;

      const isDisabled = articleWindow.__articleHighlightDisabled === true;
      toggle.setAttribute("aria-pressed", String(isDisabled));
      toggle.setAttribute(
        "aria-label",
        isDisabled ? "Enable scroll text highlight" : "Disable scroll text highlight",
      );
      toggle.title = isDisabled
        ? "Enable scroll text highlight"
        : "Disable scroll text highlight";
      toggle.classList.toggle("bg-black", isDisabled);
      toggle.classList.toggle("text-white", isDisabled);

      if (label instanceof HTMLElement) {
        label.textContent = isDisabled ? "Highlight off" : "Highlight on";
      }
    };

    const initArticleHighlightToggle = () => {
      const toggle = document.querySelector("[data-highlight-toggle]");
      if (!(toggle instanceof HTMLButtonElement)) return;
      if (toggle.dataset.bound === "true") {
        syncArticleToggleUI();
        return;
      }
      toggle.dataset.bound = "true";

      syncArticleToggleUI();

      toggle.addEventListener("click", (event) => {
        event.preventDefault();
        const article = document.getElementById("article-section");
        const isDisabled = articleWindow.__articleHighlightDisabled === true;
        articleWindow.__articleHighlightDisabled = !isDisabled;

        clearArticleTriggers();
        articleWindow.__articleHighlightCleanup?.();
        articleWindow.__articleHighlightCleanup = null;

        if (article instanceof HTMLElement) {
          resetArticleHighlightStyles(article);
        }

        syncArticleToggleUI();
        if (!articleWindow.__articleHighlightDisabled) {
          initArticleSectionHighlight();
        }
      });
    };

    const initArticleSectionHighlight = () => {
      const article = document.getElementById("article-section");
      if (!(article instanceof HTMLElement)) return;
      const title = article.querySelector("[data-article-title]");
      const triggerEl = title instanceof HTMLElement ? title : article;

      const paragraphs = Array.from(
        article.querySelectorAll("[data-reading-paragraph]"),
      );
      if (!paragraphs.length) return;

      clearArticleTriggers();
      articleWindow.__articleHighlightCleanup?.();
      articleWindow.__articleHighlightCleanup = null;

      if (articleWindow.__articleHighlightDisabled === true) {
        resetArticleHighlightStyles(article);
        syncArticleToggleUI();
        return;
      }

      ensureLenisScrollBridge();

      const allWords: HTMLElement[] = [];

      paragraphs.forEach((paragraph) => {
        if (!(paragraph instanceof HTMLElement)) return;
        const words = wrapWordsForHighlight(paragraph);
        if (!words.length) return;
        allWords.push(...words);
      });

      if (!allWords.length) return;

      const allSegments = Array.from(
        article.querySelectorAll<HTMLElement>(
          "[data-reading-word], [data-reading-spacer]",
        ),
      );

      gsap.killTweensOf(allSegments);
      gsap.set(allSegments, {
        color: "#0a1220",
        backgroundColor: "transparent",
        borderRadius: "0",
        paddingLeft: "0",
        paddingRight: "0",
        boxDecorationBreak: "clone",
        WebkitBoxDecorationBreak: "clone",
      });

      const masterTrigger = ScrollTrigger.create({
        id: `${articleTriggerIdPrefix}master`,
        trigger: triggerEl,
        start: "top 50%",
        endTrigger: article,
        end: "bottom 35%",
        scrub: 1.25,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          setWordsByProgress(allWords, self.progress);
        },
        onRefresh: () => {
          setWordsByProgress(allWords, calcArticleProgress(triggerEl, article));
        },
      });

      let rafId = 0;
      const loopUpdate = () => {
        setWordsByProgress(allWords, calcArticleProgress(triggerEl, article));
        rafId = window.requestAnimationFrame(loopUpdate);
      };
      loopUpdate();

      articleWindow.__articleHighlightCleanup = () => {
        masterTrigger.kill();
        if (rafId) {
          window.cancelAnimationFrame(rafId);
          rafId = 0;
        }
      };

      ScrollTrigger.refresh();
    };

    const bootArticleSectionHighlight = () => {
      window.requestAnimationFrame(initArticleSectionHighlight);
    };

    const bootArticleHighlightToggle = () => {
      window.requestAnimationFrame(initArticleHighlightToggle);
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bootArticleHighlightToggle, {
        once: true,
      });
      document.addEventListener("DOMContentLoaded", bootArticleSectionHighlight, {
        once: true,
      });
    } else {
      bootArticleHighlightToggle();
      bootArticleSectionHighlight();
    }

    document.addEventListener("astro:after-swap", bootArticleHighlightToggle);
    document.addEventListener("astro:after-swap", bootArticleSectionHighlight);
  </script>

  <section
    id="home-latest-slider"
    style="background-color:#d8e9e3;background-image:linear-gradient(180deg,#d8e9e3 0%,#d8e9e3 calc(100% - 88px),#eaf3f0 calc(100% - 34px),#ffffff 100%);"
    class="flex h-[calc(var(--viewport-h,100svh)-var(--nav-h,72px))] min-h-[calc(var(--viewport-h,100svh)-var(--nav-h,72px))] flex-col overflow-hidden bg-[#d8e9e3] pb-[var(--announce-h,48px)]"
  >
    <div class="min-h-0 flex-1 basis-0 bg-[#d8e9e3]">
      <div class="h-full w-full overflow-hidden px-4 py-4 sm:px-6 md:py-5 lg:px-8">
        <article class="grid h-full min-h-0 grid-cols-1 gap-6 md:grid-cols-[minmax(0,1.02fr)_minmax(360px,0.98fr)] md:items-center md:gap-8">
          <div class="flex min-h-0 flex-col justify-center md:pr-4">
            <div>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
                <p class="text-[0.78rem] font-semibold uppercase tracking-[0.16em] text-primary/68">
                  {audioRelease.type}
                </p>
                <p class="text-[0.82rem] font-semibold uppercase tracking-[0.12em] text-primary/48">
                  {audioRelease.date}
                </p>
              </div>
              <h3 class="mt-2 max-w-3xl text-left text-[1.82rem] font-bold leading-[0.95] tracking-tight text-primary md:text-[2.1rem] lg:text-[2.45rem]">
                {audioRelease.title}
              </h3>
              <p class="mt-3 max-w-2xl text-left text-[0.95rem] font-semibold leading-[1.48] text-primary/76 md:text-[1rem]">
                {audioRelease.summary}
              </p>
            </div>

            <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-3">
              <a
                href={audioRelease.href}
                class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold uppercase tracking-[0.08em] text-primary transition-colors hover:text-hover"
              >
                {audioRelease.ctaText}
                <svg
                  viewBox="0 0 20 12"
                  class="h-3 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M1 6h14"></path>
                  <path d="m11 2 4 4-4 4"></path>
                </svg>
              </a>
              <p class="text-sm font-semibold text-primary/58">
                Opens the full audio release page.
              </p>
            </div>
          </div>

          <div
            data-audio-preview
            class="rounded-[1.2rem] bg-[#e8f1f0] px-5 py-4 text-primary shadow-[0_10px_24px_rgba(10,18,32,0.06)] md:px-6 md:py-5"
          >
            <audio data-audio-el preload="metadata" class="hidden">
              <source src={audioRelease.audioSrc} type="audio/mpeg" />
              Your browser does not support the audio element.
            </audio>
            <div class="flex h-full min-h-0 flex-col justify-center">
              <div class="flex items-center justify-between gap-4">
                <div class="flex min-w-0 items-center gap-4">
                  <button
                    type="button"
                    data-audio-toggle
                    class="inline-flex h-14 w-14 shrink-0 cursor-pointer items-center justify-center rounded-full bg-primary text-white shadow-[0_10px_24px_rgba(10,18,32,0.16)] transition-colors hover:bg-hover"
                    aria-label="Play audio preview"
                  >
                    <svg
                      data-audio-icon-play
                      viewBox="0 0 20 20"
                      class="h-5 w-5 translate-x-px"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M6 4.75v10.5a.75.75 0 0 0 1.14.643l8.25-5.25a.75.75 0 0 0 0-1.286l-8.25-5.25A.75.75 0 0 0 6 4.75Z"></path>
                    </svg>
                    <svg
                      data-audio-icon-pause
                      viewBox="0 0 20 20"
                      class="hidden h-5 w-5"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M6 4.5A1.5 1.5 0 0 1 7.5 6v8A1.5 1.5 0 0 1 6 15.5h-.5A1.5 1.5 0 0 1 4 14V6a1.5 1.5 0 0 1 1.5-1.5H6Zm8.5 0A1.5 1.5 0 0 1 16 6v8a1.5 1.5 0 0 1-1.5 1.5H14a1.5 1.5 0 0 1-1.5-1.5V6A1.5 1.5 0 0 1 14 4.5h.5Z"></path>
                    </svg>
                  </button>
                  <div class="min-w-0">
                    <p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-primary/52">
                      {audioRelease.series}
                    </p>
                    <p class="mt-1 line-clamp-2 text-[1rem] font-semibold leading-snug text-primary md:text-[1.04rem]">
                      Episode 01: {audioRelease.title}
                    </p>
                  </div>
                </div>
                <p class="shrink-0 text-[0.82rem] font-semibold uppercase tracking-[0.12em] text-primary/52">
                  {audioRelease.duration}
                </p>
              </div>

              <div class="mt-5">
                <div class="flex items-center justify-between gap-3">
                  <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-primary/52">
                    Preview
                  </p>
                  <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-primary/42">
                    Audio brief
                  </p>
                </div>

                <div class="mt-4 flex items-end gap-1.5">
                  {[
                    "22%",
                    "40%",
                    "34%",
                    "58%",
                    "44%",
                    "64%",
                    "38%",
                    "72%",
                    "48%",
                    "76%",
                    "54%",
                    "68%",
                    "46%",
                    "84%",
                    "52%",
                    "66%",
                    "36%",
                    "60%",
                    "42%",
                    "74%",
                    "50%",
                    "62%",
                    "34%",
                    "56%",
                    "40%",
                    "70%",
                    "58%",
                    "64%",
                  ].map((height, index) => (
                    <span
                      data-audio-wave-bar
                      class:list={[
                        "block h-14 flex-1 rounded-sm bg-primary/12",
                        index < 10 && "bg-[#42b09a]",
                      ]}
                      style={`height:${height};`}
                    ></span>
                  ))}
                </div>

                <div class="mt-3 flex items-center justify-between text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-primary/42">
                  <span data-audio-current>00:00</span>
                  <span>Preview</span>
                  <span data-audio-duration>{audioRelease.duration}</span>
                </div>

                <button
                  type="button"
                  data-audio-progress-rail
                  class="mt-4 block w-full cursor-pointer"
                  aria-label="Seek audio preview"
                >
                  <span class="block h-2 w-full overflow-hidden rounded-full bg-primary/10">
                    <span
                      data-audio-progress-fill
                      class="block h-full rounded-full bg-[#42b09a] transition-[width] duration-150"
                      style="width:0%;"
                    ></span>
                  </span>
                </button>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
    <HeroArticleSlider
      items={midPageSliderItems}
      autoplayMs={4000}
      fitParentHeight={true}
      class="min-h-0 flex-1 basis-0 border-t border-primary/12"
    />
  </section>

  <section id="article-section" data-article-section class="border-b border-black/20 bg-white">
    <article class="mx-auto w-full max-w-5xl px-4 py-14 sm:px-6 md:py-20 lg:px-8">
      <div class="mb-4 flex items-center gap-2">
        <button
          type="button"
          data-highlight-toggle
          aria-pressed="false"
          aria-label="Disable scroll text highlight"
          title="Disable scroll text highlight"
          class="inline-flex h-8 w-8 cursor-pointer items-center justify-center border border-black text-primary transition-colors hover:bg-black hover:text-white"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M14 4 20 10 10 20H4v-6z"></path>
            <path d="M13 5 19 11"></path>
          </svg>
        </button>
        <span
          data-highlight-toggle-label
          class="text-[0.72rem] font-light uppercase tracking-[0.08em] text-primary/70"
        >
          Highlight on
        </span>
      </div>
      <h2
        data-article-title
        class="text-left text-3xl font-bold leading-tight tracking-tight text-foreground md:text-5xl"
      >
        {featuredArticle.title}
      </h2>
      <p class="mt-4 text-left text-sm font-semibold leading-relaxed text-foreground md:text-base">
        {featuredArticle.editors}
      </p>
      <div class="mt-8 text-left text-base font-medium leading-relaxed text-foreground [text-rendering:optimizeLegibility] md:text-lg">
        <figure class="float-none mx-auto mb-5 w-40 sm:w-48 md:float-right md:ml-6 md:mb-4 md:mt-1 md:w-56 lg:w-60">
          <img
            src="/articles/red-sea-ebook.pdf.png"
            alt="The Red Sea eBook cover"
            loading="lazy"
            class="h-auto w-full border border-black/20"
          />
        </figure>
        {featuredArticle.paragraphs.map((paragraph) => (
          <p data-reading-paragraph class="mb-6 last:mb-0">{paragraph}</p>
        ))}
      </div>
      <a
        href="/blog"
        class="clear-both mt-10 inline-flex cursor-pointer border border-black px-5 py-2 text-sm font-semibold uppercase tracking-[0.06em] text-primary transition-colors hover:bg-black hover:text-white"
      >
        More
      </a>
    </article>
  </section>

  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 md:py-12 lg:px-8">
      <div class="mb-5">
        <h2 class="text-3xl font-semibold leading-tight md:text-4xl">
          Publications
        </h2>
      </div>

      <div class="overflow-hidden border border-border bg-border">
        {featuredPublications.slice(0, 3).map((item) => (
          <article class="relative overflow-hidden border-b border-border bg-background px-4 py-3 last:border-b-0 md:px-5 md:py-3">
            <div class="pr-24 sm:pr-24 md:pr-28">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <p class="text-xs font-medium uppercase tracking-[0.1em] text-muted-foreground">
                  {item.type} - {item.date}
                </p>
                <p class="text-xs font-medium uppercase tracking-[0.08em] text-primary/85">
                  {item.authors}
                </p>
              </div>
              <h3 class="mt-1.5 text-lg font-semibold leading-tight md:text-xl">
                <a
                  href={item.href}
                  class="line-clamp-2 cursor-pointer transition-colors hover:text-hover"
                >
                  {item.title}
                </a>
              </h3>
              <p class="mt-1 line-clamp-1 text-sm text-muted-foreground">
                {item.excerpt}
              </p>
              <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1">
                <a
                  href={item.href}
                  class="inline-flex cursor-pointer text-xs font-semibold uppercase tracking-[0.06em] text-primary underline decoration-accent underline-offset-4 transition-colors hover:text-hover"
                >
                  Open publication
                </a>
                <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[0.72rem] font-medium tracking-[0.04em] text-primary/70">
                  {item.tags.map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>
              </div>
            </div>
            <div class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 md:right-5">
              <div class="h-[4.5rem] w-[4.5rem] overflow-hidden border border-black/15 bg-black/5 sm:h-[5rem] sm:w-[5rem] md:h-[5.75rem] md:w-[5.75rem]">
                <img
                  src={item.thumbnail}
                  alt={item.thumbnailAlt}
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              </div>
            </div>
          </article>
        ))}
      </div>
      <div class="mt-4 flex justify-center">
        <a
          href="/blog"
          class="inline-flex cursor-pointer text-sm font-semibold text-primary underline decoration-accent underline-offset-4 transition-colors hover:text-hover"
        >
          View all publications
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
      <div class="mb-10">
        <h2 class="text-4xl font-semibold leading-tight md:text-5xl">
          Projects
        </h2>
        <p class="mt-4 max-w-2xl text-base text-muted-foreground">
          Core platforms focused on research, policy dialogue, and regional cooperation.
        </p>
      </div>

      <div class="grid gap-px border border-border bg-border sm:grid-cols-2 lg:grid-cols-3">
        {activityThemes.map((item) => (
          <article
            data-project-card
            style={`--project-hover-bg:${item.hoverBg};--project-hover-title:${item.hoverTitle};--project-hover-meta:${item.hoverMeta};--project-hover-summary:${item.hoverSummary};`}
            class="bg-background p-6 transition-colors duration-300"
          >
            <a href={item.href} class="block">
              <h3
                data-project-title
                class="text-2xl font-semibold leading-tight transition-colors duration-300"
              >
                {item.title}
              </h3>
              <p
                data-project-meta
                class="mt-3 text-sm font-medium uppercase tracking-[0.08em] text-primary/85 transition-colors duration-300"
              >
                {item.meta}
              </p>
              <p
                data-project-summary
                class="mt-4 text-sm text-muted-foreground transition-colors duration-300"
              >
                {item.summary}
              </p>
              <p
                data-project-summary
                class="mt-5 text-[0.82rem] font-semibold uppercase tracking-[0.08em] text-primary transition-colors duration-300"
              >
                Open project →
              </p>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style is:inline>
    [data-project-card]:hover {
      background-color: var(--project-hover-bg);
    }

    [data-project-card]:hover [data-project-title] {
      color: var(--project-hover-title);
    }

    [data-project-card]:hover [data-project-meta] {
      color: var(--project-hover-meta);
    }

    [data-project-card]:hover [data-project-summary] {
      color: var(--project-hover-summary);
    }
  </style>

</BaseLayout>
