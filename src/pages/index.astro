const decodeEntities = (value: string) =>
  value
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'");

const stripCdata = (value: string) =>
  value.replace(/^<!\[CDATA\[/, "").replace(/\]\]>$/, "").trim();

const extractTag = (input: string, tagName: string) => {
  const match = input.match(
    new RegExp(`<${tagName}[^>]*>([\\s\\S]*?)<\\/${tagName}>`),
  );
  return match?.[1] ?? "";
};

const extractAttr = (input: string, tagName: string, attrName: string) => {
  const match = input.match(
    new RegExp(`<${tagName}[^>]*\\s${attrName}="([^"]+)"[^>]*\\/?>`),
  );
  return match?.[1] ?? "";
};

const normalizeLink = (value: string) =>
  decodeEntities(stripCdata(value)).replace(/\?at_medium=RSS&at_campaign=rss$/, "");

const upscaleBbcImage = (url: string) =>
  url.includes("/standard/240/")
    ? url.replace("/standard/240/", "/standard/1024/")
    : url;

const fillerImages = [
  "/blog/blog_post_1_1768848683359.webp",
  "/blog/blog_post_5_1768848750922.webp",
  "/blog/blog_post_8_1768850554501.webp",
  "/blog/blog_post_11_1768850597259.webp",
  "/blog/blog_post_12_1768850610966.webp",
];

let heroSliderItems = sliderNarratives.map((item, index) => ({
  ...item,
  category: item.category,
  image: item.image || fillerImages[index % fillerImages.length],
}));

try {
  const bbcFeedResponse = await fetch("https://feeds.bbci.co.uk/news/rss.xml");
  if (bbcFeedResponse.ok) {
    const bbcFeedXml = await bbcFeedResponse.text();
    const feedAssets = Array.from(bbcFeedXml.matchAll(/<item>([\s\S]*?)<\/item>/g))
      .map((match) => match[1])
      .map((itemXml) => {
        const href = normalizeLink(extractTag(itemXml, "link"));
        const image =
          extractAttr(itemXml, "media:thumbnail", "url") ||
          extractAttr(itemXml, "media:content", "url");
        return { href, image: image ? upscaleBbcImage(image) : "" };
      })
      .filter((item) => item.image);

    if (feedAssets.length > 0) {
      heroSliderItems = sliderNarratives.map((item, index) => {
        const asset = feedAssets[index % feedAssets.length];
        return {
          ...item,
          href: item.href,
          category: item.category,
          image: item.image || asset.image || fillerImages[index % fillerImages.length],
        };
      });
    }
  }
} catch (error) {
  console.error("Failed to load RSS imagery for hero slider:", error);
}

