  </style>

  <script is:inline>
    const initHeroArrow = () => {
      const trigger = document.querySelector("[data-scroll-to-latest]");
      if (!(trigger instanceof HTMLElement)) return;
      if (trigger.dataset.arrowBound === "true") return;
      trigger.dataset.arrowBound = "true";

      const revealArrow = () => {
        trigger.classList.remove("opacity-0", "pointer-events-none");
      };

      window.setTimeout(revealArrow, 10000);
    };

    const initLandingVideos = () => {
      document.querySelectorAll("[data-landing-video]").forEach((video) => {
        video.muted = true;
        video.defaultMuted = true;
        const playPromise = video.play?.();
        if (playPromise && typeof playPromise.catch === "function") {
          playPromise.catch(() => {});
        }
      });
    };

    const initSliderStatsCounter = () => {
      const section = document.getElementById("home-latest-slider");
      const statsBox = document.querySelector("[data-slider-stats]");
      if (!section || !statsBox || section.dataset.counterBound === "true") return;

      section.dataset.counterBound = "true";

      const countEls = Array.from(statsBox.querySelectorAll("[data-countup]"));
      const rafIds = new Map();
      const START_THRESHOLD = 0.55;
      let runToken = 0;
      let isActive = false;

      const animateCount = (el, target, duration, token) => {
        const start = performance.now();

        const tick = (now) => {
          if (token !== runToken) return;
          const progress = Math.min(1, (now - start) / duration);
          const value = Math.round(target * progress);
          el.textContent = String(value);
          if (progress < 1) {
            const rafId = window.requestAnimationFrame(tick);
            rafIds.set(el, rafId);
          } else {
            el.textContent = String(target);
            const rafId = rafIds.get(el);
            if (rafId) {
              window.cancelAnimationFrame(rafId);
              rafIds.delete(el);
            }
          }
        };

        el.textContent = "0";
        const rafId = window.requestAnimationFrame(tick);
        rafIds.set(el, rafId);
      };

      const resetCountup = () => {
        runToken += 1;
        section.dataset.counterDone = "false";
        countEls.forEach((el) => {
          const rafId = rafIds.get(el);
          if (rafId) {
            window.cancelAnimationFrame(rafId);
            rafIds.delete(el);
          }
          el.textContent = "0";
        });
      };

      const runCountup = () => {
        if (section.dataset.counterDone === "true") return;
        section.dataset.counterDone = "true";
        runToken += 1;
        const token = runToken;

        countEls.forEach((el, index) => {
          const target = Number(el.dataset.countupTarget || "0");
          if (!Number.isFinite(target) || target <= 0) return;
          animateCount(el, target, 420 + index * 80, token);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const entry = entries[0];
          if (!entry) return;

          if (entry.intersectionRatio >= START_THRESHOLD) {
            if (!isActive) {
              isActive = true;
              runCountup();
            }
            return;
          }

          if (entry.intersectionRatio < START_THRESHOLD) {
            if (!isActive) return;
            isActive = false;
            resetCountup();
          }
        },
        { threshold: [0, START_THRESHOLD] },
      );

      observer.observe(section);

      const rect = section.getBoundingClientRect();
      const inView =
        rect.top < window.innerHeight * 0.6 && rect.bottom > window.innerHeight * 0.4;
      if (inView) {
        isActive = true;
        runCountup();
      } else {
        resetCountup();
      }
    };

    const initHomeEnhancements = () => {
      initHeroArrow();
      initLandingVideos();
      initSliderStatsCounter();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHomeEnhancements, {
        once: true,
      });
    } else {
      initHomeEnhancements();
    }

    document.addEventListener("astro:after-swap", initHomeEnhancements);
  </script>
  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const articleTriggerIdPrefix = "article-section-highlight-";
    const articleWindow = window as Window & {
      __lenis?: { on?: (event: string, cb: () => void) => void };
      __articleLenisBridgeBound?: boolean;
      __articleHighlightCleanup?: (() => void) | null;
      __articleHighlightDisabled?: boolean;
    };

    const clearArticleTriggers = () => {
      ScrollTrigger.getAll().forEach((trigger) => {
        const triggerId = trigger.vars.id;
        if (
          typeof triggerId === "string" &&
          triggerId.startsWith(articleTriggerIdPrefix)
        ) {
          trigger.kill();
        }
      });
    };

    const ensureLenisScrollBridge = () => {
      if (articleWindow.__articleLenisBridgeBound) return;

      const tryBind = () => {
        const lenis = articleWindow.__lenis;
        if (!lenis || typeof lenis.on !== "function") return false;
        lenis.on("scroll", () => ScrollTrigger.update());
        articleWindow.__articleLenisBridgeBound = true;
        return true;
      };

      if (tryBind()) return;

      let attempts = 0;
      const retry = () => {
        attempts += 1;
        if (tryBind() || attempts > 180) return;
        window.requestAnimationFrame(retry);
      };

      window.requestAnimationFrame(retry);
    };

    const wrapWordsForHighlight = (paragraph: HTMLElement) => {
      const rawText = paragraph.textContent?.replace(/\s+/g, " ").trim() ?? "";
      if (!rawText) return [];

      const words = rawText.split(" ").filter(Boolean);
      paragraph.textContent = "";

      words.forEach((word, index) => {
        const span = document.createElement("span");
        span.dataset.readingWord = "true";
        span.className = "inline";
        span.textContent = index === words.length - 1 ? word : `${word} `;
        paragraph.append(span);
      });

      paragraph.dataset.wordsWrapped = "true";
      return Array.from(paragraph.querySelectorAll<HTMLElement>("[data-reading-word]"));
    };

    const setWordsByProgress = (words: HTMLElement[], progress: number) => {
      const clampedProgress = Math.max(0, Math.min(1, progress));
      const easedProgress = gsap.parseEase("power1.out")(clampedProgress);
      const scaled = easedProgress * words.length;

      words.forEach((word, index) => {
        const local = Math.max(0, Math.min(1, scaled - index));
        const textChannel = Math.round(local * 255);
        word.style.backgroundColor = `rgba(238, 135, 54, ${local.toFixed(3)})`;
        word.style.color = `rgb(${textChannel}, ${textChannel}, ${textChannel})`;
      });
    };

    const calcArticleProgress = (title: HTMLElement, article: HTMLElement) => {
      const titleTop = title.getBoundingClientRect().top;
      const articleBottom = article.getBoundingClientRect().bottom;
      const startPx = window.innerHeight * 0.5;
      const endPx = window.innerHeight * 0.35;
      const span = Math.max(1, articleBottom - titleTop + (startPx - endPx));
      return (startPx - titleTop) / span;
    };

    const resetArticleHighlightStyles = (article: HTMLElement) => {
      const words = Array.from(
        article.querySelectorAll<HTMLElement>("[data-reading-word]"),
      );
      words.forEach((word) => {
        word.style.backgroundColor = "transparent";
        word.style.color = "#000000";
        word.style.borderRadius = "0";
        word.style.paddingLeft = "0";
        word.style.paddingRight = "0";
      });
    };

    const syncArticleToggleUI = () => {
      const toggle = document.querySelector("[data-highlight-toggle]");
      const label = document.querySelector("[data-highlight-toggle-label]");
      if (!(toggle instanceof HTMLButtonElement)) return;

      const isDisabled = articleWindow.__articleHighlightDisabled === true;
      toggle.setAttribute("aria-pressed", String(isDisabled));
      toggle.setAttribute(
        "aria-label",
        isDisabled ? "Enable scroll text highlight" : "Disable scroll text highlight",
      );
      toggle.title = isDisabled
        ? "Enable scroll text highlight"
        : "Disable scroll text highlight";
      toggle.classList.toggle("bg-black", isDisabled);
      toggle.classList.toggle("text-white", isDisabled);

      if (label instanceof HTMLElement) {
        label.textContent = isDisabled ? "Highlight off" : "Highlight on";
      }
    };

    const initArticleHighlightToggle = () => {
      const toggle = document.querySelector("[data-highlight-toggle]");
      if (!(toggle instanceof HTMLButtonElement)) return;
      if (toggle.dataset.bound === "true") {
        syncArticleToggleUI();
        return;
      }
      toggle.dataset.bound = "true";

      syncArticleToggleUI();

      toggle.addEventListener("click", (event) => {
        event.preventDefault();
        const article = document.getElementById("article-section");
        const isDisabled = articleWindow.__articleHighlightDisabled === true;
        articleWindow.__articleHighlightDisabled = !isDisabled;

        clearArticleTriggers();
        articleWindow.__articleHighlightCleanup?.();
        articleWindow.__articleHighlightCleanup = null;

        if (article instanceof HTMLElement) {
          resetArticleHighlightStyles(article);
        }

        syncArticleToggleUI();
        if (!articleWindow.__articleHighlightDisabled) {
          initArticleSectionHighlight();
        }
      });
    };

    const initArticleSectionHighlight = () => {
      const article = document.getElementById("article-section");
      if (!(article instanceof HTMLElement)) return;
      const title = article.querySelector("[data-article-title]");
      const triggerEl = title instanceof HTMLElement ? title : article;

      const paragraphs = Array.from(
        article.querySelectorAll("[data-reading-paragraph]"),
      );
      if (!paragraphs.length) return;

      clearArticleTriggers();
      articleWindow.__articleHighlightCleanup?.();
      articleWindow.__articleHighlightCleanup = null;

      if (articleWindow.__articleHighlightDisabled === true) {
        resetArticleHighlightStyles(article);
        syncArticleToggleUI();
        return;
      }

      ensureLenisScrollBridge();

      const allWords: HTMLElement[] = [];

      paragraphs.forEach((paragraph) => {
        if (!(paragraph instanceof HTMLElement)) return;
        const words = wrapWordsForHighlight(paragraph);
        if (!words.length) return;
        allWords.push(...words);
      });

      if (!allWords.length) return;

      gsap.killTweensOf(allWords);
      gsap.set(allWords, {
        color: "#000000",
        backgroundColor: "transparent",
        borderRadius: "0",
        paddingLeft: "0",
        paddingRight: "0",
        boxDecorationBreak: "clone",
        WebkitBoxDecorationBreak: "clone",
      });

      const masterTrigger = ScrollTrigger.create({
        id: `${articleTriggerIdPrefix}master`,
        trigger: triggerEl,
        start: "top 50%",
        endTrigger: article,
        end: "bottom 35%",
        scrub: 1.25,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          setWordsByProgress(allWords, self.progress);
        },
        onRefresh: () => {
          setWordsByProgress(allWords, calcArticleProgress(triggerEl, article));
        },
      });

      let rafId = 0;
      const loopUpdate = () => {
        setWordsByProgress(allWords, calcArticleProgress(triggerEl, article));
        rafId = window.requestAnimationFrame(loopUpdate);
      };
      loopUpdate();

      articleWindow.__articleHighlightCleanup = () => {
        masterTrigger.kill();
        if (rafId) {
          window.cancelAnimationFrame(rafId);
          rafId = 0;
        }
      };

      ScrollTrigger.refresh();
    };

    const bootArticleSectionHighlight = () => {
      window.requestAnimationFrame(initArticleSectionHighlight);
    };

    const bootArticleHighlightToggle = () => {
      window.requestAnimationFrame(initArticleHighlightToggle);
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bootArticleHighlightToggle, {
        once: true,
      });
      document.addEventListener("DOMContentLoaded", bootArticleSectionHighlight, {
        once: true,
      });
    } else {
      bootArticleHighlightToggle();
      bootArticleSectionHighlight();
    }

    document.addEventListener("astro:after-swap", bootArticleHighlightToggle);
    document.addEventListener("astro:after-swap", bootArticleSectionHighlight);
  </script>

