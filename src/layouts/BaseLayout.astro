---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: string;
  publishedTime?: string | Date;
  hideAnnouncementBar?: boolean;
  metadata?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noindex?: boolean;
    ogType?: string;
    publishedTime?: string | Date;
    ignoreTitleTemplate?: boolean;
  };
}

import Seo from "../components/seo/Seo.astro";
import Schema from "../components/seo/Schema.astro";
import Navbar from "../components/layout/Navbar.astro";
import AnnouncementBar from "../components/layout/AnnouncementBar.astro";
import NewsletterSignup from "../components/layout/NewsletterSignup.astro";
import Footer from "../components/layout/Footer.astro";
import "../styles/global.css";
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";

import { siteConfig } from "../config/site";
import { getAnnouncementBarSettings } from "../lib/site-data";
import { defaultUiLanguage, uiTranslations } from "../lib/ui-i18n";

const { title, description, ogImage, canonical, noindex, ogType, publishedTime, metadata, hideAnnouncementBar = false } = Astro.props;

const finalTitle = metadata?.title || title;
const finalDescription = metadata?.description || description;
const finalOgImage = metadata?.ogImage || ogImage;
const finalCanonical = metadata?.canonical || canonical;
const finalNoindex = metadata?.noindex ?? noindex ?? false;
const finalOgType = metadata?.ogType || ogType;
const finalPublishedTime = metadata?.publishedTime || publishedTime;
const finalIgnoreTitleTemplate = metadata?.ignoreTitleTemplate || false;
const announcementSettings = hideAnnouncementBar ? undefined : await getAnnouncementBarSettings();
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <Seo
      title={finalTitle}
      description={finalDescription}
      ogImage={finalOgImage}
      canonical={finalCanonical}
      noindex={finalNoindex}
      ogType={finalOgType}
      publishedTime={finalPublishedTime}
      ignoreTitleTemplate={finalIgnoreTitleTemplate}
    />
    <Schema type="WebSite" data={{}} />
    <slot name="head" />
    <script is:inline>
      const getTheme = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      };

      const theme = getTheme();
      if (theme === "light") {
        document.documentElement.setAttribute("data-theme", "light");
      } else {
        document.documentElement.setAttribute("data-theme", "dark");
      }
      window.localStorage.setItem("theme", theme);
    </script>
    <script is:inline define:vars={{ defaultUiLanguage, uiTranslations }}>
      (() => {
        const runtime = window;
        const storageKey = "medplatform-ui-language";
        const cookieKey = "mp_ui_lang";

        const isUiLanguage = (value) =>
          typeof value === "string" && Object.prototype.hasOwnProperty.call(uiTranslations, value);

        const readLanguageCookie = () => {
          const match = document.cookie.match(new RegExp(`(?:^|; )${cookieKey}=([^;]+)`));
          return match ? decodeURIComponent(match[1]) : "";
        };

        const getStoredLanguage = () => {
          try {
            const storedLanguage = runtime.localStorage?.getItem(storageKey) || "";
            if (isUiLanguage(storedLanguage)) {
              return storedLanguage;
            }
          } catch {}

          const cookieLanguage = readLanguageCookie();
          return isUiLanguage(cookieLanguage) ? cookieLanguage : defaultUiLanguage;
        };

        const translateText = (key, language, value) => {
          const resolvedLanguage = isUiLanguage(language) ? language : defaultUiLanguage;
          const fallbackLanguage = uiTranslations[defaultUiLanguage] || {};
          const template =
            uiTranslations[resolvedLanguage]?.[key] ??
            fallbackLanguage[key] ??
            "";

          if (typeof template !== "string") {
            return "";
          }

          return typeof value === "string" && value !== ""
            ? template.replace(/\{\{value\}\}/g, value)
            : template;
        };

        const applyAttributeTranslations = (
          selector,
          dataAttributeName,
          attributeName,
          language,
        ) => {
          document.querySelectorAll(selector).forEach((element) => {
            const key = element.getAttribute(dataAttributeName);
            if (!key) {
              return;
            }

            const value = element.getAttribute("data-ui-i18n-value") || "";
            const translated = translateText(key, language, value);

            if (translated !== "") {
              element.setAttribute(attributeName, translated);
            }
          });
        };

        const applyUiLanguage = () => {
          const language = getStoredLanguage();
          document.documentElement.dataset.uiLanguage = language;
          document.documentElement.lang = language;
          document.documentElement.dir = language === "ar" ? "rtl" : "ltr";

          document.querySelectorAll("[data-ui-i18n]").forEach((element) => {
            const key = element.getAttribute("data-ui-i18n");
            if (!key) {
              return;
            }

            const value = element.getAttribute("data-ui-i18n-value") || "";
            const translated = translateText(key, language, value);

            if (translated !== "") {
              element.textContent = translated;
            }
          });

          applyAttributeTranslations(
            "[data-ui-i18n-placeholder]",
            "data-ui-i18n-placeholder",
            "placeholder",
            language,
          );
          applyAttributeTranslations(
            "[data-ui-i18n-aria-label]",
            "data-ui-i18n-aria-label",
            "aria-label",
            language,
          );
          applyAttributeTranslations(
            "[data-ui-i18n-title]",
            "data-ui-i18n-title",
            "title",
            language,
          );

          document.querySelectorAll("[data-ui-lang-button]").forEach((button) => {
            const buttonLanguage = button.getAttribute("data-ui-lang-code");
            const isActive = buttonLanguage === language;
            button.dataset.active = isActive ? "true" : "false";
            button.setAttribute("aria-pressed", String(isActive));
            button.classList.toggle("font-semibold", isActive);
            button.classList.toggle("text-primary", isActive);
            button.classList.toggle("text-primary/45", !isActive);
          });
        };

        const setUiLanguage = (language) => {
          if (!isUiLanguage(language)) {
            return;
          }

          try {
            runtime.localStorage?.setItem(storageKey, language);
          } catch {}

          document.cookie = `${cookieKey}=${encodeURIComponent(language)}; path=/; max-age=31536000; SameSite=Lax`;
          applyUiLanguage();
          document.dispatchEvent(
            new CustomEvent("mp:ui-language-change", {
              detail: { language },
            }),
          );
        };

        runtime.__mpGetUiLanguage = getStoredLanguage;
        runtime.__mpSetUiLanguage = setUiLanguage;
        runtime.__mpApplyUiLanguage = applyUiLanguage;
        runtime.__mpTranslateUi = (key, language, value) =>
          translateText(key, language || getStoredLanguage(), value);

        if (!runtime.__mpUiLanguageListenersBound) {
          document.addEventListener("click", (event) => {
            const target = event.target;
            if (!(target instanceof Element)) {
              return;
            }

            const button = target.closest("[data-ui-lang-button]");
            if (!(button instanceof HTMLButtonElement)) {
              return;
            }

            event.preventDefault();
            setUiLanguage(button.getAttribute("data-ui-lang-code") || defaultUiLanguage);
          });

          document.addEventListener("astro:page-load", applyUiLanguage);
          document.addEventListener("astro:after-swap", applyUiLanguage);
          runtime.__mpUiLanguageListenersBound = true;
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", applyUiLanguage, { once: true });
        } else {
          applyUiLanguage();
        }
      })();
    </script>
  </head>
  <body
    class="bg-background text-foreground antialiased selection:bg-accent/30 selection:text-foreground"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-50 rounded-md border border-black bg-white px-4 py-2 text-primary shadow-lg ring-2 ring-black"
    >
      Skip to content
    </a>

    <div class="relative flex min-h-screen flex-col overflow-x-hidden bg-white">
      <Navbar />
      <main
        id="main-content"
        class="relative z-10 grow bg-white"
      >
        <slot />
      </main>
      {!hideAnnouncementBar && announcementSettings && <AnnouncementBar announcement={announcementSettings} />}
      <NewsletterSignup />
      <div class="bg-white">
        <Footer />
      </div>
    </div>
    <script>
      import Lenis from "lenis";

      const runtime = window as Window & {
        __lenis?: Lenis;
        __fixedOffsetCleanup?: () => void;
        __announcementBarThemeCleanup?: () => void;
        __announcementBarThemeBound?: boolean;
      };
      const lenisInstance = new Lenis({
        duration: 1.05,
        smoothWheel: true,
        wheelMultiplier: 0.95,
        touchMultiplier: 1,
      });

      const syncFixedOffsets = () => {
        const nav = document.querySelector("nav[data-site-nav]");
        const announcement = document.querySelector("[data-announcement-bar]");
        const navHeight = nav instanceof HTMLElement ? nav.offsetHeight : 72;
        const announcementHeight =
          announcement instanceof HTMLElement ? announcement.offsetHeight : 0;
        const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;

        document.documentElement.style.setProperty(
          "--viewport-h",
          `${viewportHeight}px`,
        );
        document.documentElement.style.setProperty("--nav-h", `${navHeight}px`);
        document.documentElement.style.setProperty(
          "--announce-h",
          `${announcementHeight}px`,
        );
        document.documentElement.style.setProperty(
          "--section-h",
          `calc(${viewportHeight}px - ${navHeight}px - ${announcementHeight}px)`,
        );
      };

      runtime.__lenis = lenisInstance;

      const raf = (time: number) => {
        lenisInstance.raf(time);
        window.requestAnimationFrame(raf);
      };

      window.requestAnimationFrame(raf);
      runtime.__fixedOffsetCleanup?.();
      syncFixedOffsets();

      const observedElements = [
        document.querySelector("nav[data-site-nav]"),
        document.querySelector("[data-announcement-bar]"),
      ].filter((element): element is HTMLElement => element instanceof HTMLElement);

      const resizeObserver =
        typeof ResizeObserver !== "undefined"
          ? new ResizeObserver(() => syncFixedOffsets())
          : null;
      observedElements.forEach((element) => resizeObserver?.observe(element));

      window.addEventListener("resize", syncFixedOffsets);
      window.visualViewport?.addEventListener("resize", syncFixedOffsets);
      document.addEventListener("astro:page-load", syncFixedOffsets);
      document.addEventListener("astro:after-swap", syncFixedOffsets);

      runtime.__fixedOffsetCleanup = () => {
        resizeObserver?.disconnect();
        window.removeEventListener("resize", syncFixedOffsets);
        window.visualViewport?.removeEventListener("resize", syncFixedOffsets);
        document.removeEventListener("astro:page-load", syncFixedOffsets);
        document.removeEventListener("astro:after-swap", syncFixedOffsets);
      };

      const initAnnouncementBarTheme = () => {
        runtime.__announcementBarThemeCleanup?.();

        const bar = document.querySelector("[data-announcement-bar]");
        const footer = document.querySelector("footer");
        const main = document.getElementById("main-content");
        const themeAnchor =
          main?.querySelector(
            "[data-announcement-theme-anchor], [data-hero-section], section, article",
          ) ?? main?.firstElementChild;

        if (!(bar instanceof HTMLElement)) return;

        const landingColor = "#42b09a";
        const scrolledColor = "#0a1220";
        let rafId = 0;

        const updateTheme = () => {
          const navHeightValue =
            document.documentElement.style.getPropertyValue("--nav-h");
          const navHeight = Number.parseFloat(navHeightValue);
          const threshold = Number.isFinite(navHeight) ? navHeight + 8 : 80;
          const nextColor =
            themeAnchor instanceof HTMLElement
              ? themeAnchor.getBoundingClientRect().bottom <= threshold
                ? scrolledColor
                : landingColor
              : window.scrollY > threshold
                ? scrolledColor
                : landingColor;
          const footerOpacity =
            footer instanceof HTMLElement
              ? Math.max(
                  0,
                  Math.min(
                    1,
                    (footer.getBoundingClientRect().top -
                      (window.innerHeight - 32)) /
                      176,
                  ),
                )
              : 1;

          bar.style.opacity = footerOpacity.toFixed(3);
          bar.style.pointerEvents = footerOpacity <= 0.05 ? "none" : "auto";

          if (bar.dataset.themeColor !== nextColor) {
            bar.dataset.themeColor = nextColor;
            bar.style.setProperty("--announcement-bar-bg", nextColor);
          }
        };

        const scheduleUpdate = () => {
          if (rafId) return;
          rafId = window.requestAnimationFrame(() => {
            rafId = 0;
            updateTheme();
          });
        };

        window.addEventListener("scroll", scheduleUpdate, { passive: true });
        window.addEventListener("resize", scheduleUpdate);
        scheduleUpdate();

        runtime.__announcementBarThemeCleanup = () => {
          if (rafId) {
            window.cancelAnimationFrame(rafId);
            rafId = 0;
          }
          window.removeEventListener("scroll", scheduleUpdate);
          window.removeEventListener("resize", scheduleUpdate);
        };
      };

      if (!runtime.__announcementBarThemeBound) {
        document.addEventListener("astro:page-load", initAnnouncementBarTheme);
        document.addEventListener("astro:after-swap", initAnnouncementBarTheme);
        runtime.__announcementBarThemeBound = true;
      }

      initAnnouncementBarTheme();
    </script>
    <SpeedInsights />
    <Analytics />
    <script>
      const setupObserver = () => {
        const observerOptions = {
          root: null,
          rootMargin: "0px 0px -50px 0px", // Triggers slightly before the element fully enters
          threshold: 0.1,
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        const revealElements = document.querySelectorAll(
          ".reveal:not(.active)",
        );
        revealElements.forEach((el) => observer.observe(el));
      };

      // Run on initial load
      setupObserver();
      // Also run on Astro view-transitions if enabled
      document.addEventListener("astro:page-load", setupObserver);
    </script>
  </body>
</html>
