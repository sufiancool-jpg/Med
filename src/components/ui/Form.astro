---
import Button from "./Button.astro";

interface Props {
  action?: string;
  method?: "GET" | "POST";
  recipient?: string;
}

const defaultRecipient = "i.bertocchini@mediplatform.org";
const { action, method = "GET", recipient = defaultRecipient } = Astro.props;
const wordpressApiUrl = (import.meta.env.WORDPRESS_API_URL ?? process.env.WORDPRESS_API_URL ?? "").replace(/\/$/, "");
const submissionEndpoint = wordpressApiUrl ? `${wordpressApiUrl}/mp-headless/v1/contact` : "";
const resolvedAction = action || `mailto:${recipient}`;
---

<form
  action={resolvedAction}
  method={method}
  data-contact-form
  data-contact-recipient={recipient}
  data-contact-endpoint={submissionEndpoint}
  class="space-y-6"
>
  <div>
    <label
      for="name"
      data-ui-i18n="contact.name"
      class="mb-2 block text-sm font-medium text-foreground/80">Name</label
    >
    <input
      type="text"
      name="name"
      id="name"
      autocomplete="name"
      required
      class="block w-full rounded-xl border-border bg-muted/50 px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-primary/20 transition-all border outline-none focus:ring-4"
      placeholder="Your name"
      data-ui-i18n-placeholder="contact.namePlaceholder"
    />
  </div>
  <div>
    <label
      for="email"
      data-ui-i18n="contact.email"
      class="mb-2 block text-sm font-medium text-foreground/80">Email</label
    >
    <input
      type="email"
      name="email"
      id="email"
      autocomplete="email"
      required
      class="block w-full rounded-xl border-border bg-muted/50 px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-primary/20 transition-all border outline-none focus:ring-4"
      placeholder="your@email.com"
      data-ui-i18n-placeholder="contact.emailPlaceholder"
    />
  </div>
  <div>
    <label
      for="organisation"
      data-ui-i18n="contact.organisation"
      class="mb-2 block text-sm font-medium text-foreground/80">Organisation / Institution</label
    >
    <input
      type="text"
      name="organisation"
      id="organisation"
      autocomplete="organization"
      class="block w-full rounded-xl border-border bg-muted/50 px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-primary/20 transition-all border outline-none focus:ring-4"
      placeholder="Your organisation or institution"
      data-ui-i18n-placeholder="contact.organisationPlaceholder"
    />
  </div>
  <div>
    <label
      for="topic"
      data-ui-i18n="contact.area"
      class="mb-2 block text-sm font-medium text-foreground/80">Area of contact</label
    >
    <select
      name="topic"
      id="topic"
      required
      class="block w-full rounded-xl border border-border bg-muted/50 px-4 py-3 text-foreground focus:border-primary focus:ring-4 focus:ring-primary/20 outline-none transition-all"
    >
      <option value="" data-ui-i18n="contact.areaPlaceholder">Choose area of contact</option>
      <option value="research_partnership" data-ui-i18n="contact.area.researchPartnership">Research partnership</option>
      <option value="project_collaboration" data-ui-i18n="contact.area.projectCollaboration">Project collaboration</option>
      <option value="volunteer" data-ui-i18n="contact.area.volunteer">Volunteer</option>
      <option value="general" data-ui-i18n="contact.area.general">General info</option>
    </select>
  </div>
  <div>
    <label for="website" class="sr-only">Website</label>
    <input
      type="text"
      id="website"
      name="website"
      tabindex="-1"
      autocomplete="off"
      class="hidden"
    />
  </div>
  <div>
    <label
      for="message"
      data-ui-i18n="contact.message"
      class="mb-2 block text-sm font-medium text-foreground/80">Message</label
    >
    <textarea
      name="message"
      id="message"
      rows="4"
      required
      class="block w-full rounded-xl border-border bg-muted/50 px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-primary/20 transition-all border outline-none focus:ring-4 resize-none"
      placeholder="How can we help you?"
      data-ui-i18n-placeholder="contact.messagePlaceholder"></textarea>
  </div>
  <div>
    <Button type="submit" size="lg" class="w-full sm:w-auto" data-contact-submit>
      <span data-contact-submit-label data-ui-i18n="contact.send">Send message</span>
    </Button>
    <p
      data-contact-status
      hidden
      class="mt-3 text-sm leading-6"
    ></p>
  </div>
</form>

<script is:inline>
  const runtime = window;
  const defaultRecipient = "i.bertocchini@mediplatform.org";

  if (!runtime.__mpInitContactForms) {
    runtime.__mpInitContactForms = () => {
      document.querySelectorAll("[data-contact-form]").forEach((form) => {
        if (!(form instanceof HTMLFormElement) || form.dataset.bound === "true") {
          return;
        }

        form.dataset.bound = "true";

        const submitButton = form.querySelector("[data-contact-submit]");
        const submitLabel = form.querySelector("[data-contact-submit-label]");
        const status = form.querySelector("[data-contact-status]");
        const translateUi = (key, fallback) =>
          runtime.__mpTranslateUi?.(key, runtime.__mpGetUiLanguage?.()) ?? fallback;
        const setStatus = (message, tone = "neutral") => {
          if (!(status instanceof HTMLElement)) return;
          status.hidden = false;
          status.textContent = message;
          status.classList.remove("text-primary/72", "text-emerald-700", "text-red-700");
          status.classList.add(
            tone === "success"
              ? "text-emerald-700"
              : tone === "error"
                ? "text-red-700"
                : "text-primary/72",
          );
        };
        const setSubmitting = (isSubmitting) => {
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = isSubmitting;
          }

          if (submitLabel instanceof HTMLElement) {
            submitLabel.textContent = isSubmitting
              ? translateUi("contact.sending", "Sending...")
              : translateUi("contact.send", "Send message");
          }
        };
        const buildMailtoHref = ({ recipient, name, email, organisation, topicLabel, message }) => {
          const subject = `{${topicLabel}} Mediterranean Platform contact`;
          const body = [
            `Name: ${name}`,
            `Email: ${email}`,
            `Organisation / Institution: ${organisation || "-"}`,
            `Area: ${topicLabel}`,
            "",
            message,
          ].join("\n");

          return `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        };

        form.addEventListener("submit", async (event) => {
          event.preventDefault();

          if (!form.reportValidity()) {
            return;
          }

          setSubmitting(true);
          const recipient = form.dataset.contactRecipient || defaultRecipient;
          const endpoint = form.dataset.contactEndpoint || "";
          const formData = new FormData(form);
          const name = String(formData.get("name") || "").trim();
          const email = String(formData.get("email") || "").trim();
          const organisation = String(formData.get("organisation") || "").trim();
          const message = String(formData.get("message") || "").trim();
          const topicValue = String(formData.get("topic") || "").trim();
          const topicSelect = form.querySelector("#topic");
          const topicLabel =
            topicSelect instanceof HTMLSelectElement
              ? topicSelect.selectedOptions[0]?.textContent?.trim() || topicSelect.value
              : topicValue;

          if (status instanceof HTMLElement) {
            status.hidden = true;
          }

          const fallbackToMailClient = () => {
            setStatus(translateUi("contact.fallback", "Opening your email app..."));
            runtime.location.href = buildMailtoHref({
              recipient,
              name,
              email,
              organisation,
              topicLabel,
              message,
            });
          };

          try {
            if (!endpoint) {
              fallbackToMailClient();
              return;
            }

            const response = await fetch(endpoint, {
              method: "POST",
              body: formData,
              mode: "cors",
            });

            if (!response.ok) {
              throw new Error(`Contact request failed with status ${response.status}`);
            }

            const payload = await response.json().catch(() => ({}));
            setStatus(
              payload?.message || translateUi("contact.success", "Your message has been sent."),
              "success",
            );
            form.reset();
          } catch (error) {
            console.error(error);
            fallbackToMailClient();
          } finally {
            setSubmitting(false);
          }
        });
      });
    };

    const bootContactForms = () => runtime.__mpInitContactForms?.();

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bootContactForms, { once: true });
    } else {
      bootContactForms();
    }

    document.addEventListener("astro:after-swap", bootContactForms);
  } else {
    runtime.__mpInitContactForms?.();
  }
</script>
