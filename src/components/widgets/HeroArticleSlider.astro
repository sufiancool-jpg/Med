---
export interface HeroSliderItem {
  title: string;
  href: string;
  image: string;
  excerpt?: string;
  author: string;
  date?: string;
  category?: string;
  hashtags?: string;
}

interface Props {
  items?: HeroSliderItem[];
  class?: string;
  autoplayMs?: number;
  fitParentHeight?: boolean;
  contentPosition?: "center" | "bottom";
}

const {
  items = [],
  class: className = "",
  autoplayMs = 0,
  fitParentHeight = false,
  contentPosition = "bottom",
} = Astro.props as Props;

const isSingleItem = items.length === 1;
const baseItems =
  isSingleItem
    ? items
    : items.length >= 3
      ? items
      : items.length === 2
        ? [items[0], items[1], items[0]]
        : [];

const cloneCount = baseItems.length > 1 ? 3 : 0;
const trackItems =
  cloneCount > 0
    ? [
        ...baseItems.slice(-cloneCount),
        ...baseItems,
        ...baseItems.slice(0, cloneCount),
      ]
    : baseItems;

const getTitleSizeClass = (title: string) => {
  const length = title.trim().length;

  if (length > 130) {
    return "text-[0.92rem] sm:text-[0.94rem] md:text-[0.84rem] lg:text-[0.94rem] xl:text-[1.1rem]";
  }

  if (length > 95) {
    return "text-[0.98rem] sm:text-[1rem] md:text-[0.9rem] lg:text-[1rem] xl:text-[1.22rem]";
  }

  return "text-[1.04rem] sm:text-[1.06rem] md:text-[0.96rem] lg:text-[1.1rem] xl:text-[1.36rem]";
};
---

{
  trackItems.length > 0 ? (
    <section
      class:list={[
        fitParentHeight
          ? "relative flex min-h-0 w-full flex-col overflow-hidden bg-transparent"
          : "relative w-full overflow-hidden bg-background [--slide-h:242px] h-[var(--slide-h)]",
        className,
      ]}
      data-hero-slider
      data-base-count={baseItems.length}
      data-clone-count={cloneCount}
      data-autoplay-ms={autoplayMs}
      data-fit-parent-height={fitParentHeight ? "true" : "false"}
      aria-roledescription="carousel"
      aria-label="Featured blog articles"
      data-ui-i18n-aria-label="hero.carousel"
      tabindex="0"
    >
      <div
        class:list={[
          fitParentHeight
            ? "absolute inset-0 overflow-hidden bg-transparent"
            : "h-full w-full overflow-hidden bg-background",
        ]}
      >
        <div
          class="flex h-full items-stretch gap-0 will-change-transform transition-transform duration-500 ease-linear"
          data-slider-track
        >
          {trackItems.map((item) => (
            <article class="relative h-full min-h-full shrink-0 overflow-hidden opacity-50" data-slide>
              <a
                href={item.href}
                class="absolute inset-0 z-20"
                aria-label={`Open ${item.title}`}
                data-ui-i18n-aria-label="hero.openItem"
                data-ui-i18n-value={item.title}
              ></a>
              <img
                src={item.image}
                alt={item.title}
                class="absolute inset-0 h-full w-full scale-100 object-cover object-center md:scale-105 xl:scale-110"
                loading={fitParentHeight ? "eager" : "lazy"}
              />
              <div class="absolute inset-0 bg-black/38"></div>
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(8,15,30,0.18)_0%,rgba(8,15,30,0.42)_42%,rgba(8,15,30,0.82)_100%)]"></div>
              <div
                class:list={[
                  "pointer-events-none absolute inset-0 z-30 flex justify-start",
                  contentPosition === "bottom"
                    ? "items-center px-5 py-6 sm:px-6 sm:py-7 md:items-end md:px-6 md:pt-6 md:pb-8 lg:px-7 lg:pb-10"
                    : "items-center px-3 py-3 sm:px-4 sm:py-4 md:px-5 md:py-5",
                ]}
              >
                <div class="max-w-[82%] text-left sm:max-w-[80%] md:max-w-[84%] lg:max-w-[76%] xl:max-w-[70%]">
                  <div class="flex flex-wrap items-center gap-2">
                    {item.category && (
                      <span class="inline-flex items-center border border-white/90 bg-white/10 px-2 py-0.5 text-[9px] font-sans font-semibold uppercase leading-none tracking-[0.08em] text-white sm:px-2.5 sm:py-1 sm:text-[9px] md:text-[11px]">
                        {item.category}
                      </span>
                    )}
                    {item.hashtags && (
                      <p class="line-clamp-1 text-[9px] font-sans font-semibold uppercase tracking-[0.08em] text-white sm:text-[9px] md:text-[11px] lg:text-[12px]">
                        {item.hashtags}
                      </p>
                    )}
                  </div>
                  <p class="mt-2 inline-flex items-center gap-1.5 text-[11px] font-sans font-semibold uppercase leading-none tracking-[0.08em] text-white sm:text-[11px] md:text-[13px]">
                    <span data-ui-i18n="hero.by">By</span>
                    <span>{item.author}</span>
                  </p>
                  <h3
                    class:list={[
                      "mt-2 line-clamp-5 md:line-clamp-6 lg:line-clamp-5 font-sans font-semibold uppercase leading-[1.06] tracking-[0.035em] text-white [overflow-wrap:anywhere]",
                      getTitleSizeClass(item.title),
                    ]}
                  >
                    {item.title}
                  </h3>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      {
        baseItems.length > 1 && (
          <>
            <button
              type="button"
              data-slider-prev
              class="absolute bottom-4 left-4 z-40 inline-flex h-11 w-11 cursor-pointer items-center justify-center text-white transition-colors hover:text-white/80 sm:bottom-5 sm:left-5 sm:h-12 sm:w-12 md:top-1/2 md:bottom-auto md:left-1 md:h-20 md:w-20 md:-translate-y-1/2 lg:left-2"
              aria-label="Previous highlighted article"
              data-ui-i18n-aria-label="hero.prev"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-6 w-6 sm:h-7 sm:w-7 md:h-10 md:w-10"
                fill="none"
                stroke="currentColor"
                stroke-width="3.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M15 18l-6-6 6-6"></path>
              </svg>
            </button>
            <button
              type="button"
              data-slider-next
              class="absolute bottom-4 right-4 z-40 inline-flex h-11 w-11 cursor-pointer items-center justify-center text-white transition-colors hover:text-white/80 sm:bottom-5 sm:right-5 sm:h-12 sm:w-12 md:top-1/2 md:bottom-auto md:right-1 md:h-20 md:w-20 md:-translate-y-1/2 lg:right-2"
              aria-label="Next highlighted article"
              data-ui-i18n-aria-label="hero.next"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-6 w-6 sm:h-7 sm:w-7 md:h-10 md:w-10"
                fill="none"
                stroke="currentColor"
                stroke-width="3.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M9 18l6-6-6-6"></path>
              </svg>
            </button>
          </>
        )
      }
    </section>
  ) : (
    <p data-ui-i18n="hero.empty" class="p-5 text-sm text-muted-foreground">
      No featured articles available.
    </p>
  )
}

<script is:inline>
  const initHeroSliders = () => {
    document.querySelectorAll("[data-hero-slider]").forEach((slider) => {
      if (slider.dataset.sliderReady === "true") return;
      slider.dataset.sliderReady = "true";

      const track = slider.querySelector("[data-slider-track]");
      const slides = Array.from(slider.querySelectorAll("[data-slide]"));
      const prevButton = slider.querySelector("[data-slider-prev]");
      const nextButton = slider.querySelector("[data-slider-next]");
      if (!track || slides.length === 0) return;

      const baseCount = Number(slider.getAttribute("data-base-count") || "0");
      const cloneCount = Number(slider.getAttribute("data-clone-count") || "0");
      const autoplayMs = Number(slider.getAttribute("data-autoplay-ms") || "0");
      const fitParentHeight =
        slider.getAttribute("data-fit-parent-height") === "true";

      let index = cloneCount > 0 ? cloneCount : 0;
      let slideWidth = 0;
      let slideStep = 0;
      let centerOffset = 0;
      let timerId = 0;
      let isTransitioning = false;
      let isPhoneViewport = false;
      let isSingleVisible = false;

      const setHighlight = () => {
        const centerIndex =
          baseCount <= 1 || isSingleVisible ? index : index + 1;
        slides.forEach((slide, currentIndex) => {
          const isCenter = currentIndex === centerIndex;
          slide.dataset.active = isCenter ? "true" : "false";
          slide.style.opacity = isCenter ? "1" : "0.5";
        });
      };

      const setDimensions = () => {
        const styles = window.getComputedStyle(track);
        const gap =
          Number.parseFloat(styles.columnGap || styles.gap || "0") || 0;
        const sliderWidth = slider.clientWidth;
        if (sliderWidth <= 0) return false;
        isPhoneViewport = window.matchMedia("(max-width: 767px)").matches;
        isSingleVisible = window.matchMedia("(max-width: 1023px)").matches;
        const baseSlideWidth = ((sliderWidth - gap * 2) / 3) * 1.03;

        if (baseCount <= 1 || isSingleVisible) {
          slideWidth = sliderWidth;
          slideStep = slideWidth;
          centerOffset = 0;
        } else {
          slideWidth = baseSlideWidth;
          slideStep = slideWidth + gap;
          const visibleTrackWidth = slideWidth * 3 + gap * 2;
          centerOffset = (visibleTrackWidth - slider.clientWidth) / 2;
        }

        const slideHeight = (slideWidth * 9) / 16;

        if (fitParentHeight) {
          if (isPhoneViewport) {
            slider.style.removeProperty("height");
          } else {
            slider.style.height = `${slideHeight}px`;
          }
        } else {
          slider.style.setProperty("--slide-h", `${slideHeight}px`);
        }
        slides.forEach((slide) => {
          slide.style.width = `${slideWidth}px`;
        });
        return true;
      };

      const render = (animate = true) => {
        track.style.transitionDuration = animate ? "500ms" : "0ms";
        track.style.transform = `translateX(-${index * slideStep + centerOffset}px)`;
      };

      const syncLayout = () => {
        const hasDimensions = setDimensions();
        if (!hasDimensions) return;
        render(false);
        setHighlight();
      };

      const stopAutoplay = () => {
        if (timerId) {
          window.clearInterval(timerId);
          timerId = 0;
        }
      };

      const startAutoplay = () => {
        if (autoplayMs < 2000 || baseCount <= 1) return;
        stopAutoplay();
        timerId = window.setInterval(() => {
          goTo(index + 1);
        }, autoplayMs);
      };

      const normalizeIndexAfterTransition = () => {
        if (baseCount <= 1 || cloneCount === 0) return;

        const maxReal = cloneCount + baseCount - 1;
        if (index > maxReal) {
          index = cloneCount;
          render(false);
        } else if (index < cloneCount) {
          index = cloneCount + baseCount - 1;
          render(false);
        }
      };

      const goTo = (nextIndex) => {
        if (isTransitioning || baseCount <= 1) return;
        isTransitioning = true;
        index = nextIndex;
        render(true);
      };

      track.addEventListener("transitionend", () => {
        normalizeIndexAfterTransition();
        setHighlight();
        isTransitioning = false;
      });

      prevButton?.addEventListener("click", () => {
        goTo(index - 1);
        startAutoplay();
      });

      nextButton?.addEventListener("click", () => {
        goTo(index + 1);
        startAutoplay();
      });

      slider.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          goTo(index - 1);
          startAutoplay();
        } else if (event.key === "ArrowRight") {
          event.preventDefault();
          goTo(index + 1);
          startAutoplay();
        }
      });

      slider.addEventListener("focusin", stopAutoplay);
      slider.addEventListener("focusout", startAutoplay);

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          stopAutoplay();
        } else {
          startAutoplay();
        }
      });

      window.addEventListener("resize", () => {
        syncLayout();
      });

      const resizeObserver = new ResizeObserver(() => {
        syncLayout();
      });
      resizeObserver.observe(slider);

      syncLayout();
      window.requestAnimationFrame(syncLayout);
      startAutoplay();
    });
  };

  initHeroSliders();
  document.addEventListener("astro:after-swap", initHeroSliders);
</script>
