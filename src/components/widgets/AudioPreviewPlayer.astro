---
interface Props {
  audioSrc: string;
  title: string;
  series?: string;
  initialDuration?: string;
  containerClass?: string;
  id?: string;
  compact?: boolean;
}

const {
  audioSrc,
  title,
  series = "Mediterranean Platform Audio Brief",
  initialDuration = "00:24",
  containerClass = "",
  id,
  compact = false,
} = Astro.props;

const waveHeights = [
  "22%",
  "40%",
  "34%",
  "58%",
  "44%",
  "64%",
  "38%",
  "72%",
  "48%",
  "76%",
  "54%",
  "68%",
  "46%",
  "84%",
  "52%",
  "66%",
  "36%",
  "60%",
  "42%",
  "74%",
  "50%",
  "62%",
  "34%",
  "56%",
  "40%",
  "70%",
  "58%",
  "64%",
];

const accentWaveIndexes = new Set([1, 4, 7, 10, 13, 16, 19, 22, 25]);
const shellClass = compact
  ? "rounded-[1.1rem] border border-primary/10 bg-[#e8f1f0] px-3.5 py-3.5 text-primary shadow-[0_10px_24px_rgba(10,18,32,0.06)] sm:px-4 md:px-5 md:py-4"
  : "rounded-[1.35rem] border border-primary/10 bg-[#e8f1f0] px-4 py-4 text-primary shadow-[0_10px_24px_rgba(10,18,32,0.06)] sm:px-5 md:px-6 md:py-5";
const bodyClass = compact
  ? "flex h-full min-h-0 flex-col justify-center gap-4"
  : "flex h-full min-h-0 flex-col justify-center gap-5";
const buttonClass = compact
  ? "inline-flex h-10 w-10 shrink-0 cursor-pointer items-center justify-center rounded-full bg-primary text-white shadow-[0_10px_24px_rgba(10,18,32,0.16)] transition-colors hover:bg-hover sm:h-11 sm:w-11"
  : "inline-flex h-12 w-12 shrink-0 cursor-pointer items-center justify-center rounded-full bg-primary text-white shadow-[0_10px_24px_rgba(10,18,32,0.16)] transition-colors hover:bg-hover sm:h-14 sm:w-14";
const iconClass = compact
  ? "h-4 w-4 translate-x-px sm:h-[1.05rem] sm:w-[1.05rem]"
  : "h-[1.125rem] w-[1.125rem] translate-x-px sm:h-5 sm:w-5";
const pauseIconClass = compact
  ? "hidden h-4 w-4 sm:h-[1.05rem] sm:w-[1.05rem]"
  : "hidden h-[1.125rem] w-[1.125rem] sm:h-5 sm:w-5";
const metaClass = compact
  ? "text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-primary/52 sm:text-[0.66rem]"
  : "text-[0.66rem] font-semibold uppercase tracking-[0.18em] text-primary/52 sm:text-[0.7rem]";
const titleClass = compact
  ? "mt-1 line-clamp-2 text-[0.94rem] font-semibold leading-snug text-primary md:text-[1rem]"
  : "mt-1 line-clamp-2 text-[1rem] font-semibold leading-snug text-primary md:text-[1.08rem]";
const waveClass = compact
  ? "flex h-[2.8rem] items-end gap-[4px] sm:h-[3.1rem] md:h-[3.35rem]"
  : "flex h-[3.2rem] items-end gap-[4px] sm:h-[3.7rem] md:h-[4.1rem]";
const durationClass = compact
  ? "flex items-center justify-between text-[0.68rem] font-semibold uppercase tracking-[0.1em] text-primary/48 sm:text-[0.72rem]"
  : "flex items-center justify-between text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-primary/48 sm:text-[0.76rem]";
---

<div
  data-audio-preview
  id={id}
  class:list={[
    shellClass,
    containerClass,
  ]}
>
  <audio data-audio-el preload="metadata" class="hidden">
    <source src={audioSrc} type="audio/mpeg" />
    Your browser does not support the audio element.
  </audio>
  <div class={bodyClass}>
    <div class="flex min-w-0 items-start gap-3 sm:gap-4">
      <button
        type="button"
        data-audio-toggle
        class={buttonClass}
        aria-label="Play audio preview"
      >
        <svg
          data-audio-icon-play
          viewBox="0 0 20 20"
          class={iconClass}
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M6 4.75v10.5a.75.75 0 0 0 1.14.643l8.25-5.25a.75.75 0 0 0 0-1.286l-8.25-5.25A.75.75 0 0 0 6 4.75Z"></path>
        </svg>
        <svg
          data-audio-icon-pause
          viewBox="0 0 20 20"
          class={pauseIconClass}
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M6 4.5A1.5 1.5 0 0 1 7.5 6v8A1.5 1.5 0 0 1 6 15.5h-.5A1.5 1.5 0 0 1 4 14V6a1.5 1.5 0 0 1 1.5-1.5H6Zm8.5 0A1.5 1.5 0 0 1 16 6v8a1.5 1.5 0 0 1-1.5 1.5H14a1.5 1.5 0 0 1-1.5-1.5V6A1.5 1.5 0 0 1 14 4.5h.5Z"></path>
        </svg>
      </button>

      <div class="min-w-0 flex-1">
        <p class={metaClass}>
          {series}
        </p>
        <p class={titleClass}>
          {title}
        </p>
      </div>
    </div>

    <div class={waveClass}>
      {waveHeights.map((height, index) => (
        <span
          data-audio-wave-bar
          class:list={[
            "block flex-1 rounded-full bg-primary/12 transition-colors duration-150",
            accentWaveIndexes.has(index) && "bg-[#42b09a]",
          ]}
          style={`height:${height};`}
        ></span>
      ))}
    </div>

    <button
      type="button"
      data-audio-progress-rail
      class="block w-full cursor-pointer"
      aria-label="Seek audio preview"
    >
      <span class="block h-1.5 w-full overflow-hidden rounded-full bg-primary/10 sm:h-2">
        <span
          data-audio-progress-fill
          class="block h-full rounded-full bg-[#42b09a] transition-[width] duration-150"
          style="width:0%;"
        ></span>
      </span>
    </button>

    <div class={durationClass}>
      <span data-audio-current>00:00</span>
      <span data-audio-duration>{initialDuration}</span>
    </div>
  </div>
</div>

<script is:inline>
  const runtime = window;

  if (!runtime.__mpInitAudioPreviewPlayers) {
    runtime.__mpInitAudioPreviewPlayers = () => {
      const formatTime = (value) => {
        const totalSeconds = Number.isFinite(value) ? Math.max(0, Math.floor(value)) : 0;
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;
        return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
      };

      document.querySelectorAll("[data-audio-preview]").forEach((player) => {
        if (!(player instanceof HTMLElement) || player.dataset.bound === "true") return;

        const audio = player.querySelector("[data-audio-el]");
        const toggle = player.querySelector("[data-audio-toggle]");
        const playIcon = player.querySelector("[data-audio-icon-play]");
        const pauseIcon = player.querySelector("[data-audio-icon-pause]");
        const progressFill = player.querySelector("[data-audio-progress-fill]");
        const progressRail = player.querySelector("[data-audio-progress-rail]");
        const currentTime = player.querySelector("[data-audio-current]");
        const durationTime = player.querySelector("[data-audio-duration]");
        const waveBars = Array.from(player.querySelectorAll("[data-audio-wave-bar]"));
        const translateUi = (key, fallback) =>
          runtime.__mpTranslateUi?.(key, runtime.__mpGetUiLanguage?.()) ?? fallback;

        if (
          !(audio instanceof HTMLAudioElement) ||
          !(toggle instanceof HTMLButtonElement) ||
          !(progressFill instanceof HTMLElement) ||
          !(progressRail instanceof HTMLElement)
        ) {
          return;
        }

        player.dataset.bound = "true";

        const setPlaybackState = (isPlaying) => {
          if (playIcon instanceof Element) {
            playIcon.classList.toggle("hidden", isPlaying);
          }

          if (pauseIcon instanceof Element) {
            pauseIcon.classList.toggle("hidden", !isPlaying);
          }

          toggle.setAttribute("aria-pressed", isPlaying ? "true" : "false");
          toggle.setAttribute(
            "aria-label",
            isPlaying
              ? translateUi("audio.pausePreview", "Pause audio preview")
              : translateUi("audio.playPreview", "Play audio preview"),
          );
        };

        const syncUI = () => {
          const duration = audio.duration || 0;
          const current = audio.currentTime || 0;
          const progress = duration > 0 ? current / duration : 0;
          const activeBars = Math.round(progress * waveBars.length);
          const isPlaying = !audio.paused && !audio.ended;

          progressFill.style.width = `${progress * 100}%`;

          if (currentTime instanceof HTMLElement) {
            currentTime.textContent = formatTime(current);
          }

          if (durationTime instanceof HTMLElement) {
            durationTime.textContent = formatTime(duration || 24);
          }

          setPlaybackState(isPlaying);
          progressRail.setAttribute(
            "aria-label",
            translateUi("audio.seekPreview", "Seek audio preview"),
          );

          waveBars.forEach((bar, index) => {
            bar.classList.toggle("bg-[#42b09a]", index < activeBars);
            bar.classList.toggle("bg-primary/12", index >= activeBars);
          });
        };

        player.__mpSyncAudioPreview = syncUI;

        toggle.addEventListener("click", () => {
          if (audio.paused) {
            document.querySelectorAll("[data-audio-preview]").forEach((otherPlayer) => {
              if (!(otherPlayer instanceof HTMLElement) || otherPlayer === player) return;

              const otherAudio = otherPlayer.querySelector("[data-audio-el]");
              if (otherAudio instanceof HTMLAudioElement && !otherAudio.paused) {
                otherAudio.pause();
              }

              if (typeof otherPlayer.__mpSyncAudioPreview === "function") {
                otherPlayer.__mpSyncAudioPreview();
              }
            });

            audio
              .play()
              .then(() => {
                setPlaybackState(true);
                syncUI();
              })
              .catch(() => {
                syncUI();
              });
          } else {
            audio.pause();
            setPlaybackState(false);
            syncUI();
          }
        });

        progressRail.addEventListener("click", (event) => {
          const rect = progressRail.getBoundingClientRect();
          if (rect.width <= 0 || !audio.duration) return;
          const clickX = event.clientX - rect.left;
          const ratio = Math.max(0, Math.min(1, clickX / rect.width));
          audio.currentTime = ratio * audio.duration;
          syncUI();
        });

        audio.addEventListener("loadedmetadata", syncUI);
        audio.addEventListener("timeupdate", syncUI);
        audio.addEventListener("play", syncUI);
        audio.addEventListener("playing", syncUI);
        audio.addEventListener("pause", syncUI);
        document.addEventListener("mp:ui-language-change", syncUI);
        audio.addEventListener("ended", () => {
          audio.currentTime = 0;
          setPlaybackState(false);
          syncUI();
        });

        syncUI();
      });
    };
  }

  if (!runtime.__mpAudioPreviewListenersBound) {
    const bootAudioPreviewPlayers = () => runtime.__mpInitAudioPreviewPlayers?.();

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bootAudioPreviewPlayers, {
        once: true,
      });
    } else {
      bootAudioPreviewPlayers();
    }

    document.addEventListener("astro:after-swap", bootAudioPreviewPlayers);
    runtime.__mpAudioPreviewListenersBound = true;
  } else {
    runtime.__mpInitAudioPreviewPlayers?.();
  }
</script>
