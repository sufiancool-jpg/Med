---
interface ArchiveItem {
  title: string;
  summary: string;
  author: string;
  date: string;
  topic: string;
  type?: string;
  hashtags: string[];
  image: string;
  imageAlt: string;
  primaryLabel?: string;
  typeLabel?: string;
  href?: string;
}

interface Props {
  items: ArchiveItem[];
  containerClass?: string;
  emptyMessage?: string;
  resultsId?: string;
  searchPlaceholder?: string;
  searchPlaceholderKey?: string;
  searchPlaceholderValue?: string;
  emptyMessageKey?: string;
  emptyMessageValue?: string;
  typeOptions?: string[];
}

const {
  items,
  containerClass = "mx-auto max-w-7xl px-4 pt-0 pb-10 sm:px-6 md:pb-12 lg:px-8",
  emptyMessage = "No articles match the current search and filter combination.",
  resultsId = "archive-results",
  searchPlaceholder = "Search articles",
  searchPlaceholderKey = "archive.searchArticles",
  searchPlaceholderValue,
  emptyMessageKey = "archive.noArticlesMatch",
  emptyMessageValue,
  typeOptions,
} = Astro.props;

const topics = [...new Set(items.map((item) => item.topic).filter(Boolean))].sort();
const hashtags = [...new Set(items.flatMap((item) => item.hashtags))].sort();
const resolvedTypeOptions =
  typeOptions ??
  [...new Set(items.map((item) => item.type).filter((value): value is string => Boolean(value)))].sort();
const hasTypeFilter = resolvedTypeOptions.length > 0;
const filterGridClass = hasTypeFilter
  ? "grid gap-4 border-y border-black/10 py-4 md:grid-cols-[minmax(0,1.8fr)_repeat(3,minmax(0,1fr))] md:gap-5"
  : "grid gap-4 border-y border-black/10 py-4 md:grid-cols-[minmax(0,1.8fr)_repeat(2,minmax(0,1fr))] md:gap-5";
---

<section class="bg-white">
  <div class={containerClass} data-filter-archive-root>
    <form class={filterGridClass}>
      <label class="flex flex-col gap-2">
        <span class="text-[0.76rem] font-semibold uppercase tracking-[0.12em] text-primary/65">
          <span data-ui-i18n="archive.search">Search</span>
        </span>
        <input
          data-filter-search
          type="search"
          placeholder={searchPlaceholder}
          data-ui-i18n-placeholder={searchPlaceholderKey}
          data-ui-i18n-value={searchPlaceholderValue}
          class="h-12 border border-black/15 bg-white px-4 text-[0.95rem] text-primary outline-none transition-colors placeholder:text-primary/35 focus:border-black"
        />
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-[0.76rem] font-semibold uppercase tracking-[0.12em] text-primary/65">
          <span data-ui-i18n="archive.topic">Topic</span>
        </span>
        <select
          data-filter-topic
          class="h-12 border border-black/15 bg-white px-4 text-[0.95rem] text-primary outline-none transition-colors focus:border-black"
        >
          <option value="" data-ui-i18n="archive.allTopics">All topics</option>
          {topics.map((topic) => (
            <option value={topic.toLowerCase()}>{topic}</option>
          ))}
        </select>
      </label>

      <label class="flex flex-col gap-2">
        <span class="text-[0.76rem] font-semibold uppercase tracking-[0.12em] text-primary/65">
          <span data-ui-i18n="archive.hashtag">Hashtag</span>
        </span>
        <select
          data-filter-hashtag
          class="h-12 border border-black/15 bg-white px-4 text-[0.95rem] text-primary outline-none transition-colors focus:border-black"
        >
          <option value="" data-ui-i18n="archive.allHashtags">All hashtags</option>
          {hashtags.map((hashtag) => (
            <option value={hashtag.toLowerCase()}>#{hashtag}</option>
          ))}
        </select>
      </label>

      {hasTypeFilter && (
        <label class="flex flex-col gap-2">
          <span class="text-[0.76rem] font-semibold uppercase tracking-[0.12em] text-primary/65">
            <span data-ui-i18n="archive.type">Type</span>
          </span>
          <select
            data-filter-type
            class="h-12 border border-black/15 bg-white px-4 text-[0.95rem] text-primary outline-none transition-colors focus:border-black"
          >
            <option value="" data-ui-i18n="archive.allTypes">All types</option>
            {resolvedTypeOptions.map((type) => (
              <option value={type.toLowerCase()}>{type}</option>
            ))}
          </select>
        </label>
      )}
    </form>

    <div class="mt-5 flex flex-col gap-3 text-[0.88rem] text-primary/65 sm:flex-row sm:items-center sm:justify-between">
      <p data-filter-results-count>{items.length} articles</p>
      <button
        data-filter-reset
        type="button"
        class="inline-flex w-fit border-b border-black/20 pb-0.5 text-[0.82rem] font-semibold uppercase tracking-[0.1em] text-primary transition-colors hover:border-black hover:text-hover"
      >
        <span data-ui-i18n="archive.resetFilters">Reset filters</span>
      </button>
    </div>

    <div id={resultsId} class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
      {items.map((item) => (
        <article
          data-filter-article
          data-search={`${item.title} ${item.summary} ${item.topic} ${item.primaryLabel ?? ""} ${item.hashtags.join(" ")}`.toLowerCase()}
          data-topic={item.topic.toLowerCase()}
          data-type={(item.type ?? "").toLowerCase()}
          data-tags={item.hashtags.join("|").toLowerCase()}
          class="relative flex h-full flex-col border border-black/15 bg-white p-4 transition-colors hover:border-black/30 md:p-5"
        >
          {item.href && (
            <a href={item.href} class="absolute inset-0 z-10" aria-label={`Open ${item.title}`}></a>
          )}

          <div class="overflow-hidden">
            <img src={item.image} alt={item.imageAlt} loading="lazy" class="h-56 w-full object-cover" />
          </div>

          <div class="mt-4 flex flex-wrap items-center gap-2 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-primary/55">
            <span>{item.primaryLabel ?? "Publication"}</span>
            <span aria-hidden="true">/</span>
            <span>{item.topic}</span>
          </div>

          <h2 class="mt-3 text-[1.2rem] font-semibold leading-tight text-primary">
            {item.title}
          </h2>

          <p class="mt-3 line-clamp-3 text-[0.96rem] leading-6 text-primary/72">
            {item.summary}
          </p>

          <div class="mt-4 flex flex-wrap gap-2">
            {item.hashtags.map((hashtag) => (
              <span class="inline-flex rounded-full border border-black/10 px-3 py-1 text-[0.76rem] font-medium text-primary/72">
                #{hashtag}
              </span>
            ))}
          </div>

          <div class="mt-auto flex items-end justify-between gap-4 pt-6">
            <div>
              <p class="text-[0.78rem] uppercase tracking-[0.08em] text-primary/45">
                {item.author}
              </p>
              <p class="mt-1 text-[0.85rem] text-primary/65">{item.date}</p>
            </div>
            <span class="text-[0.82rem] font-semibold uppercase tracking-[0.1em] text-primary/65">
              {item.typeLabel ?? "Article"}
            </span>
          </div>
        </article>
      ))}
    </div>

    <p
      data-filter-empty-state
      data-ui-i18n={emptyMessageKey}
      data-ui-i18n-value={emptyMessageValue}
      class="hidden py-16 text-center text-[0.98rem] text-primary/58"
    >
      {emptyMessage}
    </p>
  </div>
</section>

<script>
  const runtime = window as Window & {
    __mpTranslateUi?: (key: string, language?: string, value?: string) => string;
    __mpGetUiLanguage?: () => string;
  };
  const archiveRoots = Array.from(
    document.querySelectorAll("[data-filter-archive-root]"),
  );

  archiveRoots.forEach((root) => {
    if (!(root instanceof HTMLElement)) {
      return;
    }

    const searchInput = root.querySelector("[data-filter-search]");
    const topicSelect = root.querySelector("[data-filter-topic]");
    const hashtagSelect = root.querySelector("[data-filter-hashtag]");
    const typeSelect = root.querySelector("[data-filter-type]");
    const resetButton = root.querySelector("[data-filter-reset]");
    const resultsCount = root.querySelector("[data-filter-results-count]");
    const emptyState = root.querySelector("[data-filter-empty-state]");
    const articleCards = Array.from(root.querySelectorAll("[data-filter-article]"));
    const translateUi = (key: string, fallback: string) =>
      runtime.__mpTranslateUi?.(key, runtime.__mpGetUiLanguage?.()) ?? fallback;
    const formatResultsLabel = (count: number) =>
      `${count} ${translateUi(count === 1 ? "archive.article" : "archive.articles", count === 1 ? "article" : "articles")}`;

    const updateResults = () => {
      const query =
        searchInput instanceof HTMLInputElement
          ? searchInput.value.trim().toLowerCase()
          : "";
      const topic =
        topicSelect instanceof HTMLSelectElement ? topicSelect.value : "";
      const hashtag =
        hashtagSelect instanceof HTMLSelectElement ? hashtagSelect.value : "";
      const type =
        typeSelect instanceof HTMLSelectElement ? typeSelect.value : "";

      let visibleCount = 0;

      articleCards.forEach((card) => {
        if (!(card instanceof HTMLElement)) {
          return;
        }

        const searchValue = card.dataset.search ?? "";
        const topicValue = card.dataset.topic ?? "";
        const typeValue = card.dataset.type ?? "";
        const hashtagsValue = (card.dataset.tags ?? "").split("|").filter(Boolean);

        const matchesSearch = !query || searchValue.includes(query);
        const matchesTopic = !topic || topicValue === topic;
        const matchesType = !type || typeValue === type;
        const matchesHashtag = !hashtag || hashtagsValue.includes(hashtag);
        const isVisible = matchesSearch && matchesTopic && matchesType && matchesHashtag;

        card.classList.toggle("hidden", !isVisible);

        if (isVisible) {
          visibleCount += 1;
        }
      });

      if (resultsCount instanceof HTMLElement) {
        resultsCount.textContent = formatResultsLabel(visibleCount);
      }

      if (emptyState instanceof HTMLElement) {
        emptyState.classList.toggle("hidden", visibleCount !== 0);
      }
    };

    [searchInput, topicSelect, hashtagSelect, typeSelect].forEach((control) => {
      if (control instanceof HTMLInputElement || control instanceof HTMLSelectElement) {
        control.addEventListener("input", updateResults);
        control.addEventListener("change", updateResults);
      }
    });

    resetButton?.addEventListener("click", () => {
      if (searchInput instanceof HTMLInputElement) {
        searchInput.value = "";
      }

      if (topicSelect instanceof HTMLSelectElement) {
        topicSelect.value = "";
      }

      if (hashtagSelect instanceof HTMLSelectElement) {
        hashtagSelect.value = "";
      }

      if (typeSelect instanceof HTMLSelectElement) {
        typeSelect.value = "";
      }

      updateResults();
    });

    document.addEventListener("mp:ui-language-change", updateResults);
    updateResults();
  });
</script>
