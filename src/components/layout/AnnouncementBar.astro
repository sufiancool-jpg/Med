---
import type { AnnouncementBarSettings } from "../../lib/site-data";

interface Props {
  announcement: AnnouncementBarSettings;
}

const { announcement } = Astro.props;
const resolvedText = announcement.text?.trim() || "Announcement";
const resolvedLinkLabel = announcement.linkLabel?.trim() || "Learn more";
const resolvedLinkHref = announcement.linkHref?.trim() || "/";
---

<section
  data-announcement-bar
  style="--announcement-bar-bg:#42b09a;background-color:var(--announcement-bar-bg);"
  class="fixed inset-x-0 bottom-0 z-40 h-12 text-white/90 transition-[background-color,opacity] duration-500 ease-out md:h-14"
>
  <div class="mx-auto flex h-full max-w-6xl items-center justify-center gap-3 px-4 text-center sm:px-6 md:gap-5 lg:px-8">
    <p class="min-w-0 flex-1 truncate text-[0.9rem] font-bold leading-none md:text-[1rem]">
      {resolvedText}
    </p>
    <a
      href={resolvedLinkHref}
      data-announcement-cta
      class="inline-flex shrink-0 cursor-pointer items-center border border-white/90 bg-white/10 px-3 py-1 text-[0.82rem] font-semibold leading-none tracking-[0.06em] uppercase text-white transition-colors hover:border-white hover:bg-white md:text-[0.88rem]"
    >
      {resolvedLinkLabel}
    </a>
  </div>
</section>

<style is:inline>
  [data-announcement-cta]:hover,
  [data-announcement-cta]:focus-visible {
    color: var(--announcement-bar-bg);
  }
</style>
